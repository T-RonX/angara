{% extends 'base.html.twig' %}

{% block title %}Angara - Body Explorer{% endblock %}

{# Skip the Vue SPA entirely: this view is a self-contained Three.js scene,
   now powered by the modular renderer under public/explorer/. #}
{% block stylesheets %}{% endblock %}
{% block javascripts %}{% endblock %}

{% block body %}
    <div id="scene-root"></div>

    <div id="hud">
        <h1>Body Explorer</h1>
        <div class="row"><button id="modeBtn" disabled>Enter resource mode</button></div>
        <div class="row" id="resourceControls" hidden>
            <div id="compassWrap" aria-hidden="true">
                <svg id="compass" viewBox="-50 -50 100 100">
                    <circle cx="0" cy="0" r="44" fill="rgba(0,0,0,0.35)" stroke="rgba(120,180,255,0.5)" stroke-width="1"></circle>
                    <g id="compassRose">
                        <polygon points="0,-40 6,0 0,-8 -6,0" fill="#ff6b6b"></polygon>
                        <polygon points="0,40 6,0 0,8 -6,0" fill="#dcebff" opacity="0.6"></polygon>
                        <line x1="-40" y1="0" x2="40" y2="0" stroke="rgba(120,180,255,0.35)" stroke-width="1"></line>
                        <text x="0" y="-30" text-anchor="middle" fill="#ff9090" font-size="12" font-weight="700">N</text>
                        <text x="30" y="4" text-anchor="middle" fill="#cfe3ff" font-size="10">E</text>
                        <text x="0" y="36" text-anchor="middle" fill="#cfe3ff" font-size="10">S</text>
                        <text x="-30" y="4" text-anchor="middle" fill="#cfe3ff" font-size="10">W</text>
                    </g>
                </svg>
            </div>
            <div class="hint">
                <strong>Drag ↔</strong> moves N/S along the cliff<br>
                <strong>Drag ↕</strong> spins the meridian (changes longitude)<br>
                <strong>Click</strong> a cell to glide to it &nbsp;·&nbsp; <strong>Wheel</strong> zooms
            </div>
        </div>
        <hr>
        <div class="readout">
            <div><span class="k">Mode</span><span class="v" id="rMode">view</span></div>
            <div><span class="k">Selected</span><span class="v" id="rSelected">— pick a surface cell</span></div>
            <div><span class="k">Hover lon</span><span class="v" id="rLon">—</span></div>
            <div><span class="k">Hover lat</span><span class="v" id="rLat">—</span></div>
            <div><span class="k">Hover depth</span><span class="v" id="rDepth">—</span></div>
            <hr>
            <div><span class="k">Focus</span><span class="v" id="rSlice">—</span></div>
        </div>
        <hr>
        <div class="readout">
            <div><span class="k">Selected cell</span><span class="v" id="rSelType">— none</span></div>
            <div><span class="k">Sel lon</span><span class="v" id="rSelLon">—</span></div>
            <div><span class="k">Sel lat</span><span class="v" id="rSelLat">—</span></div>
            <div><span class="k">Sel layer</span><span class="v" id="rSelLayer">—</span></div>
        </div>
        <hr>
        <div class="readout">
            <div><span class="k">FPS</span><span class="v" id="rFps">—</span></div>
            <div><span class="k">Frame</span><span class="v" id="rFrameMs">—</span></div>
            <div><span class="k">Calls</span><span class="v" id="rCalls">—</span></div>
            <div><span class="k">Tris</span><span class="v" id="rTris">—</span></div>
            <div><span class="k">Points</span><span class="v" id="rPoints">—</span></div>
            <div><span class="k">Lines</span><span class="v" id="rLines">—</span></div>
            <div><span class="k">Geoms</span><span class="v" id="rGeoms">—</span></div>
            <div><span class="k">Textures</span><span class="v" id="rTextures">—</span></div>
        </div>
        <hr>
        <div class="sliders">
            {# Per-sun controls are generated here by SliderPanel — one group
               per sun in the config, so the UI tracks the star count. #}
            <div id="sunSliders"></div>
            <label>Night darkness <span class="v" id="rNightDark">—</span>
                <input type="range" id="nightDark" min="0" max="1" step="0.01">
            </label>
        </div>
        <div class="hint">View mode: click + drag to orbit, scroll to zoom. Click a surface cell to select it, then enter resource mode.</div>
    </div>

    <style>
        html, body { height: 100%; margin: 0; background: #05070d; overflow: hidden; }
        #scene-root { position: fixed; inset: 0; }
        #scene-root canvas { display: block; }

        #hud {
            position: fixed; top: 16px; left: 16px; z-index: 10;
            width: 240px; padding: 14px 16px;
            max-height: calc(100vh - 32px);
            overflow-x: hidden; overflow-y: auto;
            scrollbar-width: none; -ms-overflow-style: none;
            background: rgba(10, 16, 28, 0.82);
            border: 1px solid rgba(120, 180, 255, 0.25);
            border-radius: 10px;
            color: #cfe3ff;
            font-family: 'Segoe UI', system-ui, sans-serif;
            font-size: 13px;
            backdrop-filter: blur(6px);
            user-select: none;
        }
        #hud::-webkit-scrollbar { width: 0; height: 0; }
        #hud:hover, #hud:focus-within {
            scrollbar-width: thin;
            scrollbar-color: rgba(120, 180, 255, 0.45) rgba(0, 0, 0, 0);
        }
        #hud:hover::-webkit-scrollbar, #hud:focus-within::-webkit-scrollbar { width: 6px; height: 6px; }
        #hud:hover::-webkit-scrollbar-track, #hud:focus-within::-webkit-scrollbar-track { background: transparent; }
        #hud:hover::-webkit-scrollbar-thumb, #hud:focus-within::-webkit-scrollbar-thumb {
            background: rgba(120, 180, 255, 0.45);
            border-radius: 999px;
            border: 2px solid transparent;
            background-clip: content-box;
        }
        #hud h1 { font-size: 15px; margin: 0 0 10px; color: #9fc6ff; letter-spacing: .5px; }
        #hud hr { border: none; border-top: 1px solid rgba(120,180,255,.18); margin: 10px 0; }
        #hud .row { margin-bottom: 8px; }
        #hud button {
            width: 100%; padding: 8px 10px; cursor: pointer;
            background: #1b2c4a; color: #dcebff;
            border: 1px solid rgba(120,180,255,.35); border-radius: 6px;
            font-size: 13px;
        }
        #hud button:hover { background: #244067; }
        #hud button:disabled { opacity: .4; cursor: not-allowed; }
        #hud .hint { color: #7f97bb; font-size: 11px; line-height: 1.5; margin-top: 6px; }
        #hud .readout div { display: flex; justify-content: space-between; padding: 2px 0; }
        #hud .readout .k { color: #7f97bb; }
        #hud .readout .v { color: #eaf3ff; font-variant-numeric: tabular-nums; }
        #hud .sliders label {
            display: flex; flex-direction: column; gap: 4px;
            margin-bottom: 8px; color: #7f97bb; font-size: 11px;
        }
        #hud .sliders label .v { color: #eaf3ff; float: right; }
        #hud .sliders input[type=range] { width: 100%; accent-color: #4f8bff; }
        /* Per-sun control groups generated by SliderPanel. */
        #hud .sun-group {
            border-top: 1px solid rgba(120,180,255,.12);
            padding-top: 6px; margin-bottom: 6px;
        }
        #hud .sun-group:first-child { border-top: none; padding-top: 0; }
        #hud .sun-title { color: #9fc6ff; font-size: 11px; font-weight: 700; margin-bottom: 4px; }

        #compassWrap {
            display: flex; justify-content: center; margin: 4px 0 8px;
        }
        #compass {
            width: 88px; height: 88px;
            filter: drop-shadow(0 1px 4px rgba(0,0,0,0.5));
        }
        /* The rose rotates so its N marker aligns with true north on screen. */
        #compassRose {
            transform-origin: 0 0;
            transition: none; /* updated every frame from JS */
        }
    </style>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/",
            "three-mesh-bvh": "https://unpkg.com/three-mesh-bvh@0.7.8/build/index.module.js"
        }
    }
    </script>

    {# The whole renderer now lives in modular, SOLID plain-JS under
       public/explorer/. This is just the loader. #}
    <script type="module" src="/explorer/index.js"></script>
{% endblock %}
