{% extends 'base.html.twig' %}

{% block title %}Angara — Body Explorer{% endblock %}

{# Skip the Vue SPA entirely: this view is a self-contained Three.js scene. #}
{% block stylesheets %}{% endblock %}
{% block javascripts %}{% endblock %}

{% block body %}
    <div id="scene-root"></div>

    <div id="hud">
        <h1>Body Explorer</h1>
        <div class="row"><button id="modeBtn" disabled>Enter resource mode</button></div>
        <div class="row" id="resourceControls" hidden>
            <div id="compassWrap" aria-hidden="true">
                <svg id="compass" viewBox="-50 -50 100 100">
                    <circle cx="0" cy="0" r="44" fill="rgba(0,0,0,0.35)" stroke="rgba(120,180,255,0.5)" stroke-width="1"></circle>
                    <g id="compassRose">
                        <polygon points="0,-40 6,0 0,-8 -6,0" fill="#ff6b6b"></polygon>
                        <polygon points="0,40 6,0 0,8 -6,0" fill="#dcebff" opacity="0.6"></polygon>
                        <line x1="-40" y1="0" x2="40" y2="0" stroke="rgba(120,180,255,0.35)" stroke-width="1"></line>
                        <text x="0" y="-30" text-anchor="middle" fill="#ff9090" font-size="12" font-weight="700">N</text>
                        <text x="30" y="4" text-anchor="middle" fill="#cfe3ff" font-size="10">E</text>
                        <text x="0" y="36" text-anchor="middle" fill="#cfe3ff" font-size="10">S</text>
                        <text x="-30" y="4" text-anchor="middle" fill="#cfe3ff" font-size="10">W</text>
                    </g>
                </svg>
            </div>
            <div class="hint">
                <strong>Drag ↔</strong> moves N/S along the cliff<br>
                <strong>Drag ↕</strong> spins the meridian (changes longitude)<br>
                <strong>Drag ↕</strong> spins the meridian (changes longitude)<br>
                <strong>Click</strong> a cell to glide to it &nbsp;·&nbsp; <strong>Wheel</strong> zooms
            </div>
        </div>
        <hr>
        <div class="readout">
            <div><span class="k">Mode</span><span class="v" id="rMode">view</span></div>
            <div><span class="k">Selected</span><span class="v" id="rSelected">— pick a surface cell</span></div>
            <div><span class="k">Hover lon</span><span class="v" id="rLon">—</span></div>
            <div><span class="k">Hover lat</span><span class="v" id="rLat">—</span></div>
            <div><span class="k">Hover depth</span><span class="v" id="rDepth">—</span></div>
            <hr>
            <div><span class="k">Focus</span><span class="v" id="rSlice">—</span></div>
        </div>
        <hr>
        <div class="readout">
            <div><span class="k">FPS</span><span class="v" id="rFps">—</span></div>
            <div><span class="k">Frame</span><span class="v" id="rFrameMs">—</span></div>
        </div>
        <hr>
        <div class="sliders">
            <label>Sun azimuth <span class="v" id="rSunAz">—</span>
                <input type="range" id="sunAz" min="0" max="360" step="1">
            </label>
            <label>Sun elevation <span class="v" id="rSunEl">—</span>
                <input type="range" id="sunEl" min="-90" max="90" step="1">
            </label>
            <label>Sun intensity <span class="v" id="rSunInt">—</span>
                <input type="range" id="sunInt" min="0" max="3" step="0.05">
            </label>
        </div>
        <div class="hint">View mode: click + drag to orbit, scroll to zoom. Click a surface cell to select it, then enter resource mode.</div>
    </div>

    <style>
        html, body { height: 100%; margin: 0; background: #05070d; overflow: hidden; }
        #scene-root { position: fixed; inset: 0; }
        #scene-root canvas { display: block; }

        #hud {
            position: fixed; top: 16px; left: 16px; z-index: 10;
            width: 240px; padding: 14px 16px;
            background: rgba(10, 16, 28, 0.82);
            border: 1px solid rgba(120, 180, 255, 0.25);
            border-radius: 10px;
            color: #cfe3ff;
            font-family: 'Segoe UI', system-ui, sans-serif;
            font-size: 13px;
            backdrop-filter: blur(6px);
            user-select: none;
        }
        #hud h1 { font-size: 15px; margin: 0 0 10px; color: #9fc6ff; letter-spacing: .5px; }
        #hud hr { border: none; border-top: 1px solid rgba(120,180,255,.18); margin: 10px 0; }
        #hud .row { margin-bottom: 8px; }
        #hud button {
            width: 100%; padding: 8px 10px; cursor: pointer;
            background: #1b2c4a; color: #dcebff;
            border: 1px solid rgba(120,180,255,.35); border-radius: 6px;
            font-size: 13px;
        }
        #hud button:hover { background: #244067; }
        #hud button:disabled { opacity: .4; cursor: not-allowed; }
        #hud .hint { color: #7f97bb; font-size: 11px; line-height: 1.5; margin-top: 6px; }
        #hud .readout div { display: flex; justify-content: space-between; padding: 2px 0; }
        #hud .readout .k { color: #7f97bb; }
        #hud .readout .v { color: #eaf3ff; font-variant-numeric: tabular-nums; }
        #hud .sliders label {
            display: flex; flex-direction: column; gap: 4px;
            margin-bottom: 8px; color: #7f97bb; font-size: 11px;
        }
        #hud .sliders label .v { color: #eaf3ff; float: right; }
        #hud .sliders input[type=range] { width: 100%; accent-color: #4f8bff; }

        #compassWrap {
            display: flex; justify-content: center; margin: 4px 0 8px;
        }
        #compass {
            width: 88px; height: 88px;
            filter: drop-shadow(0 1px 4px rgba(0,0,0,0.5));
        }
        /* The rose rotates so its N marker aligns with true north on screen. */
        #compassRose {
            transform-origin: 0 0;
            transition: none; /* updated every frame from JS */
        }
    </style>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
        }
    }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        // ----------------------------------------------------------------------
        // CONFIG — tweak these to change the appearance of the body & its grid.
        // ----------------------------------------------------------------------
        const CONFIG = {
            planetRadius:   500,    // radius of the body
            lonCells:       24 * 10,    // grid divisions around the equator (longitude)
            latCells:       12 * 10,    // grid divisions from pole to pole (latitude)
            maxDepth:        5,    // number of crust layers (any reasonable number)
            // Per-layer thickness (length must be >= maxDepth; entries past
            // maxDepth are ignored). Set to null to auto-generate a sensible
            // monotonically-thickening default — deeper layers get a touch
            // taller, which reads well at game scale.
            layerThicknesses: null,
            // Auto-thickness knobs (only used when `layerThicknesses === null`).
            //   thickness(d) = layerThicknessBase + d * layerThicknessGrowth
            layerThicknessBase:   10,
            layerThicknessGrowth: 2,
            // Inner sphere (the "core") is shown beneath the deepest crust
            // layer in resource mode. Pick a colour that clearly contrasts the
            // crust layers so the core reads as a distinct object.
            coreColor:    0xc9743a,
            // one color per depth layer (index 0 = surface ... deeper). The
            // deepest layer intentionally matches the *old* dark crust tone so
            // it blends into the crust strata rather than into the core.
            depthColors: [0x6f8b57, 0x8a6d3b, 0x2a2f3a],
            // Sun / lighting (interactive; the HUD sliders write to these).
            sunAzimuth:    35,         // degrees around Y (0 = +X, 90 = +Z)
            sunElevation:  35,         // degrees above the equator (-90..90)
            sunIntensity:  1.1,
            sunColor:      0xffffff,
            sunDistance:   8000,       // distance of the visible sun disc
            sunSize:       500,        // radius of the visible sun disc
            // Soft additive corona around the sun core; expressed as a multiple
            // of `sunSize`. Lower = subtler bloom.
            sunHaloScale:  3.0,
            sunHaloOpacity: 0.55,
            // Faint chromatic halo ring just outside the sun. The hues cycle
            // around the ring (chromatic dispersion from the optics), with
            // a sun-coloured warm bloom at the centre, a primary halo ring,
            // a thinner phase-shifted secondary diffraction ring, and dust
            // speckles for natural imperfections. Rotates very slowly so the
            // speckle pattern reads as detail, not motion.
            chromaRingScale:   2.10,
            chromaRingOpacity: 0.42,
            chromaRingSpeed:   2.5,
            // Subtle starburst: thin radial rays through the sun, the
            // signature "lens" look. Counter-rotates slowly against the
            // chroma ring so the two don't feel locked together.
            sunStarScale:    3.6,
            sunStarOpacity:  0.45,
            sunStarSpeed:   -2,
            // How smoothly the occlusion fraction (and therefore the
            // flare's fade in / out) tracks the body covering the sun. The
            // measurement itself is analytical (closed-form overlap of the
            // body and sun discs as seen from the camera), so it's free —
            // this knob only governs the temporal EMA.
            flareOcclusionEase:    0.18,
            // Tints used when generating the procedural sun + flare textures.
            // Stylised warm-white core fading through amber to a deep red rim.
            sunCoreColor:  '255, 248, 220',     // r,g,b 0-255
            sunWarmColor:  '255, 180,  90',
            sunRimColor:   '255,  90,  35',
            showSun:       true,
            // Lens flare — a chain of subtle additive elements running from the
            // sun through screen centre. Disable for a clean shot.
            showLensFlare:    true,
            lensFlareOpacity: 0.25,    // global multiplier on the flare elements
            // Hemispheric fill on the unlit side. Kept low so the night side
            // reads as genuinely shadowed but stays just visible enough to
            // make out the silhouette and surface grid.
            ambientIntensity: 0.12,
            rimIntensity:  0.4,
            // Hemisphere fill â€” soft sky/ground light that follows surface
            // normal.y, used to keep the anti-sun hemisphere visible
            // without flattening the directional sunlight modelling.
            hemiSkyColor:    0xa8c0e8,
            hemiGroundColor: 0xa37a52,
            hemiIntensity:   0.85,
            // Tiny dedicated below-fill: the hemisphere light only lights
            // surfaces by normal.y, so the polar cap cone walls (normal.y
            // ~ 0) get almost nothing from it. A dim directional from -Y
            // bottoms them up so the south pole reads as lit terrain.
            bottomFillIntensity: 0.18,
            // Distance of the "sky" — sun visual + stars are anchored to the
            // camera at this radius so they appear to be at infinity (no
            // parallax between them or against the body).
            skyDistance:   80000,
            // Star field
            showStars:     true,
            starCount:     2500,
            // Stars draw at a per-star size in screen pixels. Most stars are
            // small; a few "bright" ones are larger. The actual size is sampled
            // with a power-law bias toward starSizeMin.
            starSizeMin:   0.6,
            starSizeMax:   3.5,
            starSizeBias:  4,          // exponent; higher = more tiny stars
            // Per-star colour is sampled from a Planckian (blackbody) curve in
            // this temperature range (Kelvin). 3000K = warm orange/red,
            // 6000K ≈ sun, 10000K+ = blue-white.
            starTempMin:   3000,
            starTempMax:   12000,
            starTempBias:  2,          // exponent; higher = more cooler/redder stars
            starBrightnessMin: 0.45,
            starBrightnessMax: 1.0,
            gridColor:    0x0a0e16,
            background:   0x05070d,
            cellGap:      0.0,     // gap between cells (fraction); 0 = touching
            // Resource-mode camera framing. `crustTilt` is the angle (radians)
            // above the meridian plane — higher values look down at the surface
            // more, revealing terrain above the cut. `crustHeightBias` lifts the
            // look-at target along the surface normal (as a fraction of the
            // crust thickness) so the cliff sits lower on screen.
            crustTilt:        0.40,
            crustHeightBias:  0.2,
            // Default resource-mode zoom as a multiple of the crust thickness
            // (planetRadius - coreRadius). Clamped between crustZoomMin/Max.
            crustZoom:        2.6,
            crustZoomMin:     1.2,
            crustZoomMax:     7.0,
            // Drag-to-stroll sensitivity in resource mode.
            //   1   = cursor 1:1 with the surface (one screen pixel of drag
            //         moves the focus point one screen pixel).
            //   0.5 = half speed, 2 = double speed, etc.
            dragSensitivity:  1,
            // Cells closer to a pole than this latitude (degrees) collapse into
            // a single round "cap" cell per pole, per depth. Set to 90 to
            // disable. Snapped to the nearest row of the latCells grid.
            polarCapLat:      80,
            // Fan resolution for the polar cap geometry. Defaults to lonCells
            // so the boundary lines up with the surrounding cell columns.
            polarCapFan:      null,
            // How many latitudinal subdivisions to use inside each polar cap.
            // The cap was previously a single cone (pole → boundary ring) which
            // looks visibly pointy. Subdividing it into concentric rings that
            // sit on the actual sphere surface gives a smooth, rounded pole.
            polarCapRings:    6,
            // Cell-snapped drag in resource mode: both axes (longitude and
            // latitude) follow the cursor continuously while dragging, then
            // ease to the nearest cell on release. `focusSnapEase` is the
            // per-frame fraction of the remaining distance to the target —
            // larger = snappier, smaller = more "gliding".
            focusSnapEase:    0.22,
            // ------------------------------------------------------------------
            // Atmosphere — analytical single-scattering Rayleigh + Mie shell
            // rendered on the back faces of a slightly larger sphere. The
            // shader integrates the view ray through the atmosphere and the
            // sample-to-sun rays once per fragment (low step counts; cheap),
            // so the colour reacts naturally to the sun direction: cool blue
            // limb on the day side, warm orange/red rim at the terminator
            // (sunrise / sunset look), darker on the night side.
            //
            // All values are CONFIGurable so the look can be retuned per
            // planet (e.g. dusty Mars-like = redder Rayleigh + larger Mie).
            // ------------------------------------------------------------------
            showAtmosphere:        true,
            // Atmosphere thickness, as a fraction of `planetRadius`. Earth
            // is ~100/6371 ≈ 0.016, but a thicker shell reads much better
            // at game scale so we exaggerate.
            atmosphereThickness:   0.03,
            // Sun energy poured into the atmosphere integral. Independent
            // from `sunIntensity` so the rim glow can be tuned without
            // affecting the directional light on the surface.
            atmosphereSunIntensity: 1.0,
            // Overall opacity multiplier applied on top of the scattering
            // result (1 = physical, lower = subtler).
            atmosphereOpacity:     1.0,
            // Base colour of the atmosphere. This is the primary colour
            // knob and it participates in the *physics*: it multiplies the
            // Rayleigh scattering coefficient inside the shader, so it
            // affects both how light is scattered TOWARD the camera and
            // how it is attenuated along long sight-paths.
            //
            // The consequence is that you get the right "two-colour" look
            // for free: a blue base colour means blue scatters most, which
            // produces a blue day-side sky AND warm red/orange light at
            // the terminator (because blue is preferentially scattered out
            // of the grazing sight-paths near sunrise/sunset, leaving red
            // to reach the eye). A red base colour reverses it — reddish
            // sky with bluish twilight, à la Mars. A neutral [1,1,1] base
            // colour produces a literally colourless grey atmosphere with
            // no terminator reddening at all (no spectral physics left to
            // produce it). The default below is Earth's R:G:B ≈ 1 : 2.27
            // : 5.6 scattering ratio, normalised around its mean so the
            // overall optical depth stays sensible.
            atmosphereBaseColor:   [0.34, 0.77, 1.89],
            // Rayleigh scattering coefficient magnitude (per scene unit).
            // This is the overall *density* of the atmosphere — kept
            // spectrally neutral here because the colour comes from
            // `atmosphereBaseColor` (the shader uses `coeff * baseColor`
            // for both scattering and attenuation, so the wavelength
            // physics is still correct). Crank all three up for a denser
            // / hazier atmosphere, drop them for a thinner one. The
            // ~0.22 default matches Earth's overall optical depth.
            atmosphereRayleighCoeff: [0.222, 0.222, 0.222],
            // Rayleigh / Mie scale heights — expressed as a FRACTION of the
            // atmosphere thickness so they stay sensible when `thickness`
            // changes. Earth Rayleigh ≈ 8/100 = 0.08; Mie ≈ 1.2/100 = 0.012.
            // We exaggerate so the limb glow has visible depth on screen.
            atmosphereRayleighScaleFrac: 0.30,
            atmosphereMieScaleFrac:      0.12,
            // Mie scattering (aerosols / dust) — single grey coefficient and
            // forward-scattering asymmetry `g` (0 = isotropic, →1 = strongly
            // forward; ~0.76 matches Earth's haze around the sun).
            atmosphereMieCoeff:    0.21,
            atmosphereMieG:        0.76,
            // Integration sample counts.
            atmosphereViewSteps:   12,
            atmosphereLightSteps:  6,
        };

        // ----------------------------------------------------------------------
        // Derived layer geometry — per-layer thickness + cumulative radii.
        //
        // `layerThicknesses[d]` is the thickness of layer d; `layerRadii[d]` is
        // the OUTER radius of layer d (so layerRadii[d+1] is its inner radius,
        // and layerRadii[maxDepth] is the core radius). Computed once so the
        // rest of the code can index layers without re-deriving radii.
        //
        // `depthColors` is padded to `maxDepth` entries by interpolating the
        // last user-supplied colour toward `coreColor` — that way any number
        // of layers gets a sensible "fading into the core" gradient without
        // the user having to enumerate them all.
        // ----------------------------------------------------------------------
        const maxDepth = CONFIG.maxDepth;

        const layerThicknesses = (() => {
            const explicit = CONFIG.layerThicknesses;

            if (Array.isArray(explicit) && explicit.length >= maxDepth)
            {
                return explicit.slice(0, maxDepth);
            }

            const out = new Array(maxDepth);
            for (let d = 0; d < maxDepth; d++)
            {
                out[d] = CONFIG.layerThicknessBase + d * CONFIG.layerThicknessGrowth;
            }

            return out;
        })();

        const layerRadii = (() => {
            const out = new Array(maxDepth + 1);
            out[0] = CONFIG.planetRadius;
            for (let d = 0; d < maxDepth; d++)
            {
                out[d + 1] = out[d] - layerThicknesses[d];
            }

            return out;
        })();

        const coreRadius = layerRadii[maxDepth];

        // Pad / extend depthColors to exactly maxDepth entries.
        const depthColors = (() => {
            const src = CONFIG.depthColors.slice();
            if (src.length >= maxDepth) return src.slice(0, maxDepth);

            // Interpolate the last provided colour toward `coreColor` for the
            // remaining layers so the strata visibly deepen into the core.
            const last = new THREE.Color(src[src.length - 1]);
            const core = new THREE.Color(CONFIG.coreColor);
            const missing = maxDepth - src.length;
            for (let i = 1; i <= missing; i++)
            {
                const t = i / (missing + 1);
                src.push(last.clone().lerp(core, t * 0.5).getHex());
            }

            return src;
        })();

        // --- Polar caps -------------------------------------------------------
        // Cells very close to a pole degenerate into slivers as cos(lat) → 0.
        // We replace the top/bottom `capRows` rows of the lat grid with one
        // round cap cell per pole per depth, keeping the rest of the grid
        // uniform.
        const rowDegLat = 180 / CONFIG.latCells;
        const capRows = CONFIG.polarCapLat >= 90
            ? 0
            : Math.min(
                Math.floor(CONFIG.latCells / 2),
                Math.ceil((90 - CONFIG.polarCapLat) / rowDegLat),
            );
        const capBoundaryLatN =  90 - capRows * rowDegLat;
        const capBoundaryLatS = -90 + capRows * rowDegLat;
        const capFan = CONFIG.polarCapFan ?? CONFIG.lonCells;

        // ----------------------------------------------------------------------
        // Scene / renderer / camera
        // ----------------------------------------------------------------------
        const root = document.getElementById('scene-root');
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(CONFIG.background);

        // Far plane is generous: needs to cover the camera + skyDistance with
        // headroom so distant stars don't clip.
        const camera = new THREE.PerspectiveCamera(50, 1, 1, 200000);
        camera.position.set(0, CONFIG.planetRadius * 1.4, CONFIG.planetRadius * 2.6);

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setPixelRatio(window.devicePixelRatio);
        renderer.localClippingEnabled = true; // needed for resource-mode slicing
        root.appendChild(renderer.domElement);

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.08;
        controls.enablePan = false; // always orbit around the body center
        // Zoom clamps so the user can't dolly inside the body or out past the
        // star sphere.
        controls.minDistance = CONFIG.planetRadius * 1.15;
        controls.maxDistance = CONFIG.planetRadius * 20;

        // Hoisted here because sun/star init below already needs it. The rest
        // of the geometry helpers are defined later but use the same alias.
        const deg2rad = THREE.MathUtils.degToRad;

        const ambient = new THREE.AmbientLight(0xffffff, CONFIG.ambientIntensity);
        scene.add(ambient);
        const sun = new THREE.DirectionalLight(CONFIG.sunColor, CONFIG.sunIntensity);
        scene.add(sun);
        const rim = new THREE.DirectionalLight(0x88aaff, CONFIG.rimIntensity);
        rim.position.set(-1, -0.5, -1);
        scene.add(rim);
        // Hemisphere fill: sky-tone for upward-facing surfaces, warm rocky
        // tone for downward-facing ones. The directional `sun` alone leaves
        // the anti-sunward hemisphere of the planet (typically the south
        // cap when the sun is above the equator) reading as solid black
        // because the cap's outer normals point ~straight down. A
        // hemisphere light is a per-vertex y-dot-axis fill — almost
        // free to compute, no shadow recalc — and makes the south side
        // legible without flattening the day-side modelling.
        const hemiFill = new THREE.HemisphereLight(
            CONFIG.hemiSkyColor,
            CONFIG.hemiGroundColor,
            CONFIG.hemiIntensity,
        );
        scene.add(hemiFill);
        // Small directional fill from below to lift the polar cap cone
        // walls whose near-horizontal normals get almost nothing from
        // the hemisphere light's y-dot-axis distribution. Tinted very
        // slightly warm so the south pole reads as lit terrain.
        const bottomFill = new THREE.DirectionalLight(0xffe0c0, CONFIG.bottomFillIntensity);
        bottomFill.position.set(0, -1, 0);
        scene.add(bottomFill);

        // ----------------------------------------------------------------------
        // Sun core, corona & lens flare
        //
        // Built from procedural canvas radial gradients with additive blending
        // — cheap, no external textures, and the tints are driven from CONFIG.
        // ----------------------------------------------------------------------
        function radialGradientTexture(stops, size = 256) {
            const c = document.createElement('canvas');
            c.width = c.height = size;
            const ctx = c.getContext('2d');
            const g = ctx.createRadialGradient(size / 2, size / 2, 0, size / 2, size / 2, size / 2);
            for (const [pos, color] of stops) g.addColorStop(pos, color);
            ctx.fillStyle = g;
            ctx.fillRect(0, 0, size, size);
            const tex = new THREE.CanvasTexture(c);
            tex.colorSpace = THREE.SRGBColorSpace;
            tex.anisotropy = 4;
            return tex;
        }

        function additiveSprite(texture, opacity, depthTest) {
            const mat = new THREE.SpriteMaterial({
                map: texture,
                blending: THREE.AdditiveBlending,
                transparent: true,
                depthTest,
                depthWrite: false,
                opacity,
            });
            return new THREE.Sprite(mat);
        }

        // ----------------------------------------------------------------------
        // Sky anchor — a group that tracks the camera's position every frame
        // so that anything parented to it (sun visual, stars) effectively sits
        // at infinity. This prevents parallax between the sun, stars and the
        // body as the camera orbits. The DirectionalLight stays in world
        // space (its direction is what matters, not its position).
        // ----------------------------------------------------------------------
        const skyAnchor = new THREE.Group();
        scene.add(skyAnchor);

        // Sun core: hot white-yellow at centre fading to a warm rim. depthTest
        // is on so the planet can eclipse the sun properly.
        const sunCoreTex = radialGradientTexture([
            [0.00, `rgba(${CONFIG.sunCoreColor}, 1.0)`],
            [0.40, `rgba(${CONFIG.sunCoreColor}, 1.0)`],
            [0.55, `rgba(${CONFIG.sunWarmColor}, 0.85)`],
            [0.80, `rgba(${CONFIG.sunRimColor}, 0.18)`],
            [1.00, `rgba(${CONFIG.sunRimColor}, 0.0)`],
        ]);

        // Outer corona: large, soft, mostly transparent. Tuned to be subtle —
        // a gentle bloom, not a fireball.
        const sunHaloTex = radialGradientTexture([
            [0.00, `rgba(${CONFIG.sunCoreColor}, 0.40)`],
            [0.15, `rgba(${CONFIG.sunWarmColor}, 0.18)`],
            [0.40, `rgba(${CONFIG.sunRimColor}, 0.05)`],
            [1.00, `rgba(${CONFIG.sunRimColor}, 0.0)`],
        ]);

        // Anamorphic horizontal streak through the sun — that signature lens
        // smear you get from a bright point source through a wide lens.
        // ----------------------------------------------------------------------
        // Iridescent / rainbow helpers
        //
        // Lens-flare ghosts in the real world are tinted by chromatic
        // dispersion through the optical stack — they aren't grey blobs.
        // These helpers build the painted-canvas textures we need:
        //   * `hsvToRgb`            — HSV → linear-ish RGB in 0..1.
        //   * `rainbowHaloTexture`  — multi-layer chromatic halo (warm
        //                              core bloom, primary halo ring, thin
        //                              secondary diffraction ring, dust
        //                              speckle); drawn AT the sun and
        //                              depth-tested so the planet hides it.
        //   * `hexGhostTexture`     — hexagonal iris aperture in a single hue;
        //                              the bread-and-butter lens-flare ghost.
        // ----------------------------------------------------------------------
        function hsvToRgb(h, s, v) {
            h = ((h % 360) + 360) % 360;
            const c = v * s;
            const x = c * (1 - Math.abs(((h / 60) % 2) - 1));
            const m = v - c;
            let r, g, b;

            if (h < 60)       [r, g, b] = [c, x, 0];
            else if (h < 120) [r, g, b] = [x, c, 0];
            else if (h < 180) [r, g, b] = [0, c, x];
            else if (h < 240) [r, g, b] = [0, x, c];
            else if (h < 300) [r, g, b] = [x, 0, c];
            else              [r, g, b] = [c, 0, x];

            return [r + m, g + m, b + m];
        }

        // Multi-layer chromatic halo around the sun. Built procedurally on a
        // canvas so we can stack:
        //   * a sun-coloured central bloom (warm core → warm rim from CONFIG),
        //   * a primary halo whose colours blend warm sunlight with a
        //     hue-cycle (the "rainbowish" tint the user asked for),
        //   * a secondary thin diffraction ring at a phase-shifted hue,
        //   * scattered "dust" speckles for the imperfections you'd actually
        //     see through a real optical stack.
        // The whole thing is depth-tested so the planet correctly hides it.
        function rainbowHaloTexture(size = 1024) {
            const c = document.createElement('canvas');
            c.width = c.height = size;
            const ctx = c.getContext('2d');
            const half = size / 2;
            const img = ctx.createImageData(size, size);

            const parseRGB = (s) => s.split(',').map((v) => parseInt(v.trim(), 10));
            const core = parseRGB(CONFIG.sunCoreColor);
            const warm = parseRGB(CONFIG.sunWarmColor);

            // Layer radii (in 0..1 normalised image space).
            const R_BLOOM_OUT  = 0.30;
            const R_PRIMARY_IN = 0.30;
            const R_PRIMARY_OUT= 0.46;
            const R_SECOND_IN  = 0.47;
            const R_SECOND_OUT = 0.50;

            for (let y = 0; y < size; y++)
            {
                for (let x = 0; x < size; x++)
                {
                    const dx = (x - half) / half;
                    const dy = (y - half) / half;
                    const r = Math.hypot(dx, dy);

                    if (r > R_SECOND_OUT) continue;

                    const theta = Math.atan2(dy, dx);
                    const i = (y * size + x) * 4;
                    let R = 0, G = 0, B = 0, A = 0;

                    // --- Inner warm bloom ----------------------------------
                    if (r < R_BLOOM_OUT)
                    {
                        const t = r / R_BLOOM_OUT;
                        // Lerp core → warm → rim toward outside; gives a warm
                        // halo that *originates* from the sun's actual colour.
                        const tw = Math.min(1, t * 1.15);
                        const cR = core[0] * (1 - tw) + warm[0] * tw;
                        const cG = core[1] * (1 - tw) + warm[1] * tw;
                        const cB = core[2] * (1 - tw) + warm[2] * tw;
                        // Soft falloff with a slight inward dome.
                        const fall = (1 - t) ** 2;
                        const bloomA = fall * 0.40;
                        R = cR * bloomA;
                        G = cG * bloomA;
                        B = cB * bloomA;
                        A = bloomA;
                    }

                    // --- Primary halo ring ---------------------------------
                    if (r > R_PRIMARY_IN && r < R_PRIMARY_OUT)
                    {
                        const t = (r - R_PRIMARY_IN) / (R_PRIMARY_OUT - R_PRIMARY_IN);
                        // Soft inner edge, sharper outer (where the diffraction
                        // sits) — `^1.4` peaks slightly past mid-thickness.
                        const ringMask = Math.sin(t * Math.PI) ** 1.4;
                        // Spectral hue around the ring, low saturation so it
                        // mixes well with the warm sun tint underneath.
                        const hue = (theta / (2 * Math.PI) + 0.5) * 360;
                        const [hR, hG, hB] = hsvToRgb(hue, 0.45, 1);
                        // Per-angle imperfection + faint radial micro-rings,
                        // simulating dust / coating irregularities.
                        const azMod  = 0.78 + 0.22 * Math.sin(theta * 7 + 1.3)
                                            + 0.10 * Math.sin(theta * 23 + 4.7);
                        const radMod = 0.88 + 0.12 * Math.sin(r * 120);
                        // Blend the warm sun palette with the hue-shifted ring
                        // so the colour reads as "tinted sunlight", not pure
                        // rainbow.
                        const blend = 0.55;
                        const rR = ((warm[0] / 255) * (1 - blend) + hR * blend) * 255;
                        const rG = ((warm[1] / 255) * (1 - blend) + hG * blend) * 255;
                        const rB = ((warm[2] / 255) * (1 - blend) + hB * blend) * 255;
                        const ringA = ringMask * 0.55 * azMod * radMod;
                        R = R + rR * ringA;
                        G = G + rG * ringA;
                        B = B + rB * ringA;
                        A = Math.max(A, ringA);
                    }

                    // --- Secondary diffraction ring (thin, hue-shifted) ----
                    if (r > R_SECOND_IN && r < R_SECOND_OUT)
                    {
                        const t = (r - R_SECOND_IN) / (R_SECOND_OUT - R_SECOND_IN);
                        const ringMask = Math.sin(t * Math.PI) ** 2;
                        // Shift the secondary hue 60° from the primary so the
                        // two rings read as separate diffraction orders.
                        const hue = (theta / (2 * Math.PI) + 0.5) * 360 + 60;
                        const [hR, hG, hB] = hsvToRgb(hue, 0.75, 1);
                        const azMod = 0.7 + 0.3 * Math.sin(theta * 11 + 0.8);
                        const ringA = ringMask * 0.35 * azMod;
                        R = R + hR * 255 * ringA;
                        G = G + hG * 255 * ringA;
                        B = B + hB * 255 * ringA;
                        A = Math.max(A, ringA);
                    }

                    img.data[i]     = Math.min(255, R);
                    img.data[i + 1] = Math.min(255, G);
                    img.data[i + 2] = Math.min(255, B);
                    img.data[i + 3] = Math.min(255, A * 255);
                }
            }

            ctx.putImageData(img, 0, 0);

            // --- Dust speckle / sub-aperture diffraction motes -------------
            // Tiny additive points scattered across the ring radii. Their
            // hues are sampled from the same warm/rainbow palette so they
            // feel of-a-piece with the halo, not glued on. A small fraction
            // are notably brighter to break up the regularity.
            ctx.globalCompositeOperation = 'lighter';
            // Tiny deterministic LCG so the dust pattern is identical run to
            // run (no risk of the halo flickering between page loads).
            let s = 1337;
            const rand = () => { s = (s * 1664525 + 1013904223) >>> 0; return s / 4294967296; };

            for (let k = 0; k < 140; k++)
            {
                const a = rand() * Math.PI * 2;
                // Bias speckles to the bright primary ring band.
                const rr = (R_PRIMARY_IN + 0.02 + rand() * (R_PRIMARY_OUT - R_PRIMARY_IN - 0.04)) * half;
                const x = half + Math.cos(a) * rr;
                const y = half + Math.sin(a) * rr;
                // Mostly warm-tinted speckles, occasional cool/rainbow flecks.
                let hue;
                if (rand() < 0.35) hue = ((a / (Math.PI * 2)) + 0.5) * 360;
                else               hue = 25 + rand() * 35; // amber-ish
                const [hR, hG, hB] = hsvToRgb(hue, 0.45, 1);
                const big = rand() < 0.15;
                const radius = big ? 2.2 + rand() * 1.5 : 0.8 + rand() * 0.9;
                const alpha  = big ? 0.55 + rand() * 0.35 : 0.25 + rand() * 0.35;
                ctx.fillStyle = `rgba(${Math.round(hR*255)}, ${Math.round(hG*255)}, ${Math.round(hB*255)}, ${alpha})`;
                ctx.beginPath();
                ctx.arc(x, y, radius, 0, Math.PI * 2);
                ctx.fill();
            }

            const tex = new THREE.CanvasTexture(c);
            tex.colorSpace = THREE.SRGBColorSpace;
            tex.anisotropy = 4;

            return tex;
        }

        // (iridescentRingTexture removed: the screen-centre rainbow ring was
        // anchored at the chain's mid-point and therefore landed on top of the
        // planet whenever the body was near the optical axis. The rainbow now
        // lives in the depth-tested chromatic halo around the sun instead.)

        function hexGhostTexture(hue, size = 256, saturation = 0.55) {
            const c = document.createElement('canvas');
            c.width = c.height = size;
            const ctx = c.getContext('2d');
            const [rC, gC, bC] = hsvToRgb(hue, saturation, 1);
            const col = `${Math.round(rC * 255)}, ${Math.round(gC * 255)}, ${Math.round(bC * 255)}`;
            const cx = size / 2, cy = size / 2;
            const R = size * 0.46;

            ctx.save();
            ctx.beginPath();

            for (let i = 0; i < 6; i++)
            {
                const a = (i / 6) * Math.PI * 2 + Math.PI / 6;
                const px = cx + R * Math.cos(a);
                const py = cy + R * Math.sin(a);

                if (i === 0) ctx.moveTo(px, py);
                else         ctx.lineTo(px, py);
            }

            ctx.closePath();
            ctx.clip();

            const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, R);
            g.addColorStop(0.00, `rgba(${col}, 0.95)`);
            g.addColorStop(0.55, `rgba(${col}, 0.38)`);
            g.addColorStop(1.00, `rgba(${col}, 0.0)`);
            ctx.fillStyle = g;
            ctx.fillRect(0, 0, size, size);
            // Thin bright rim follows the aperture edge — sells the iris read.
            ctx.strokeStyle = `rgba(${col}, 0.55)`;
            ctx.lineWidth = Math.max(1, size / 256);
            ctx.stroke();
            ctx.restore();

            const tex = new THREE.CanvasTexture(c);
            tex.colorSpace = THREE.SRGBColorSpace;
            tex.anisotropy = 4;

            return tex;
        }

        // Soft circular ghost in a single colour (rgb is a "r, g, b" string,
        // matching the CONFIG colour fields). Used for the majority of the
        // restrained, off-white lens-flare ghosts. Subtle by design — these
        // are NOT supposed to read as coloured blobs.
        function softGhostTexture(rgb, peakAlpha = 0.6, size = 256) {
            const c = document.createElement('canvas');
            c.width = c.height = size;
            const ctx = c.getContext('2d');
            const cx = size / 2;
            const g = ctx.createRadialGradient(cx, cx, 0, cx, cx, cx);
            g.addColorStop(0.00, `rgba(${rgb}, ${peakAlpha})`);
            g.addColorStop(0.55, `rgba(${rgb}, ${peakAlpha * 0.22})`);
            g.addColorStop(1.00, `rgba(${rgb}, 0)`);
            ctx.fillStyle = g;
            ctx.fillRect(0, 0, size, size);
            const tex = new THREE.CanvasTexture(c);
            tex.colorSpace = THREE.SRGBColorSpace;
            tex.anisotropy = 4;

            return tex;
        }

        // Anamorphic starburst with two superimposed ray sets at different
        // counts/thicknesses ("primary" + "secondary"), micro-rays in between
        // for the natural-irregularity look, and per-ray subtle hue shifts so
        // it doesn't read as a sterile monochrome cross. Slowly rotated each
        // frame in updateLensFlare.
        function starburstTexture(size = 1024, primaryRays = 6, secondaryRays = 8) {
            const c = document.createElement('canvas');
            c.width = c.height = size;
            const ctx = c.getContext('2d');
            const cx = size / 2;

            const parseRGB = (s) => s.split(',').map((v) => parseInt(v.trim(), 10));
            const core = parseRGB(CONFIG.sunCoreColor);
            const warm = parseRGB(CONFIG.sunWarmColor);
            const coreStr = `${core[0]}, ${core[1]}, ${core[2]}`;
            const warmStr = `${warm[0]}, ${warm[1]}, ${warm[2]}`;

            // Faint central diffraction blob so the rays don't shoot out of
            // nothing.
            const g = ctx.createRadialGradient(cx, cx, 0, cx, cx, size * 0.34);
            g.addColorStop(0.00, `rgba(${coreStr}, 0.55)`);
            g.addColorStop(0.55, `rgba(${warmStr}, 0.10)`);
            g.addColorStop(1.00, `rgba(${warmStr}, 0.0)`);
            ctx.fillStyle = g;
            ctx.fillRect(0, 0, size, size);

            ctx.globalCompositeOperation = 'lighter';
            ctx.lineCap = 'round';

            const drawRays = (count, baseAngle, lenScale, widthA, widthB, alphaBase, hueShift) => {
                for (let i = 0; i < count; i++)
                {
                    // Slight per-ray length / strength jitter (deterministic
                    // per ray index) sells the "real lens" imperfection.
                    const jitter = Math.sin(i * 12.9898 + baseAngle * 78.233) * 0.5 + 0.5;
                    const lenJ   = lenScale * (0.78 + 0.22 * jitter);
                    const alphaJ = alphaBase * (0.65 + 0.55 * jitter);
                    const a = baseAngle + (i / count) * Math.PI * 2;
                    const ex = cx + Math.cos(a) * size * lenJ;
                    const ey = cx + Math.sin(a) * size * lenJ;
                    // Per-ray hue shift around amber, mostly warm but with
                    // occasional cool flecks → faint chromatic dispersion
                    // along the rays.
                    const hue = (35 + hueShift + jitter * 50) % 360;
                    const [hR, hG, hB] = hsvToRgb(hue, 0.30 + jitter * 0.15, 1);
                    const tint = `${Math.round(hR * 255)}, ${Math.round(hG * 255)}, ${Math.round(hB * 255)}`;
                    const grad = ctx.createLinearGradient(cx, cx, ex, ey);
                    grad.addColorStop(0.00, `rgba(${coreStr}, ${alphaJ})`);
                    grad.addColorStop(0.12, `rgba(${tint}, ${alphaJ * 0.7})`);
                    grad.addColorStop(0.45, `rgba(${tint}, ${alphaJ * 0.20})`);
                    grad.addColorStop(1.00, `rgba(${tint}, 0)`);
                    ctx.strokeStyle = grad;
                    ctx.lineWidth = (i % 2 === 0 ? widthA : widthB) * (size / 512);
                    ctx.beginPath();
                    ctx.moveTo(cx, cx);
                    ctx.lineTo(ex, ey);
                    ctx.stroke();
                }
            };

            // Primary set: long, thick, warm — 6 rays in a star.
            drawRays(primaryRays, 0, 0.48, 2.8, 1.4, 0.55, 0);
            // Secondary set: rotated, thinner, more rainbow — adds depth.
            drawRays(secondaryRays, Math.PI / 7, 0.40, 1.4, 0.7, 0.38, 130);
            // Faint micro-rays: many short rays at random angles for the
            // "iris coating scattering" texture.
            ctx.globalAlpha = 0.45;

            for (let i = 0; i < 36; i++)
            {
                const a   = (i / 36) * Math.PI * 2 + 0.13;
                const len = size * (0.10 + 0.10 * Math.sin(i * 3.1));
                const ex  = cx + Math.cos(a) * len;
                const ey  = cx + Math.sin(a) * len;
                const hue = (25 + (i * 13) % 60);
                const [hR, hG, hB] = hsvToRgb(hue, 0.45, 1);
                const tint = `${Math.round(hR * 255)}, ${Math.round(hG * 255)}, ${Math.round(hB * 255)}`;
                ctx.strokeStyle = `rgba(${tint}, 0.45)`;
                ctx.lineWidth = 0.8 * (size / 512);
                ctx.beginPath();
                ctx.moveTo(cx, cx);
                ctx.lineTo(ex, ey);
                ctx.stroke();
            }

            ctx.globalAlpha = 1;

            const tex = new THREE.CanvasTexture(c);
            tex.colorSpace = THREE.SRGBColorSpace;
            tex.anisotropy = 4;

            return tex;
        }

        const chromaRingTex = rainbowHaloTexture();
        const sunStarTex    = starburstTexture();

        const chromaRing = additiveSprite(chromaRingTex, CONFIG.chromaRingOpacity, true);
        const sunStar    = additiveSprite(sunStarTex,    CONFIG.sunStarOpacity,    true);
        const sunCore = additiveSprite(sunCoreTex, 1.0, true);
        const sunHalo = additiveSprite(sunHaloTex, CONFIG.sunHaloOpacity, true);

        // Draw order: halo < starburst < chroma ring < core, so the bright
        // core sits on top and the rays read against the warm halo behind
        // them. The chroma ring is a delicate tint that mostly disappears
        // unless you look right at the sun.
        sunHalo.renderOrder    = 0;
        sunStar.renderOrder    = 1;
        chromaRing.renderOrder = 2;
        sunCore.renderOrder    = 3;
        skyAnchor.add(sunHalo);
        skyAnchor.add(sunStar);
        skyAnchor.add(chromaRing);
        skyAnchor.add(sunCore);

        // --- Lens flare chain --------------------------------------------------
        // Each element is an additive sprite with its own gradient + size +
        // alpha + offset along the sun→screen-centre line (in NDC). Placement
        // is updated per frame from `updateLensFlare()` below.
        //
        // These ghosts are NOT depth-tested (they're a post-process effect),
        // so we deliberately keep them small and avoid any element that sits
        // right at screen centre — otherwise it would always read as a blob
        // pasted on top of the planet. The actual chromatic halo is anchored
        // on the sun (depth-tested) and handles the "halo near the sun" job.
        const flareSpecs = [
            // Warm cream ghost just off the sun.
            { offset: 0.22, size: 0.16,  alpha: 0.28, breath: 0.4, tex: softGhostTexture(CONFIG.sunCoreColor, 0.65) },
            // Small warm-tinted hex iris (very low saturation).
            { offset: 0.42, size: 0.045, alpha: 0.40, breath: 0.3, tex: hexGhostTexture( 35, 256, 0.22) },
            // Cool off-white iris a little past it.
            { offset: 0.62, size: 0.035, alpha: 0.45, breath: 0.3, tex: hexGhostTexture(205, 256, 0.20) },
            // Faintly cool soft ghost a little past centre.
            { offset: 1.25, size: 0.09,  alpha: 0.18, breath: 0.5, tex: softGhostTexture('210, 225, 245', 0.5) },
            // Tiny bright hex iris glint.
            { offset: 1.42, size: 0.04,  alpha: 0.50, breath: 0.35, tex: hexGhostTexture(180, 256, 0.18) },
            // Distant warm soft fade.
            { offset: 1.78, size: 0.18,  alpha: 0.14, breath: 0.5, tex: softGhostTexture(CONFIG.sunWarmColor, 0.4) },
        ];

        const flareElements = flareSpecs.map((spec) => {
            const sprite = additiveSprite(spec.tex, spec.alpha, /* depthTest */ false);
            sprite.renderOrder = 999;          // draw over everything
            sprite.frustumCulled = false;      // we manage visibility ourselves
            sprite.visible = false;
            scene.add(sprite);

            return { ...spec, sprite };
        });

        // Helper: convert azimuth/elevation (degrees) into a unit direction
        // vector pointing FROM the planet TO the light source.
        function sunDirection(azDeg, elDeg) {
            const az = deg2rad(azDeg), el = deg2rad(elDeg);
            const ce = Math.cos(el);
            return new THREE.Vector3(ce * Math.cos(az), Math.sin(el), ce * Math.sin(az));
        }

        // Current sun direction (cached; updated by `updateSun()`).
        const sunDir = new THREE.Vector3();

        // Forward-declared so `updateSun()` (called during init, before the
        // atmosphere block runs) can safely poke at it. The real object is
        // assigned further down where the shader is built.
        let atmosphereUniforms = null;

        function updateSun() {
            sunDir.copy(sunDirection(CONFIG.sunAzimuth, CONFIG.sunElevation));

            // DirectionalLight: position relative to target (origin) defines
            // the light direction. Magnitude doesn't matter — but we still use
            // skyDistance so dev tooling shows it at a sensible location.
            sun.position.copy(sunDir).multiplyScalar(CONFIG.skyDistance);
            sun.intensity = CONFIG.sunIntensity;

            // Tie the rest of the lighting model to the sun's intensity so
            // the slider behaves like an actual "how bright is this star"
            // dial instead of only dimming the direct light:
            //
            //  * The atmosphere shader receives `atmosphereSunIntensity *
            //    sunIntensity`, so the rim glow / sky brightness fades with
            //    the star — otherwise the limb stays just as bright when the
            //    surface goes dark, which reads as broken.
            //  * Ambient + rim fill scale with sunIntensity too. They model
            //    light that ultimately *comes from the sun* (planet shine,
            //    bounce, sky fill). With a constant ambient, dimming the sun
            //    makes the night side look relatively brighter than the
            //    day side, which is the opposite of what should happen.
            if (atmosphereUniforms)
            {
                atmosphereUniforms.uSunIntensity.value =
                    CONFIG.atmosphereSunIntensity * CONFIG.sunIntensity;
            }

            // Sun visuals live under `skyAnchor`. Their LOCAL position is the
            // direction × skyDistance — and because `skyAnchor.position` is
            // synced to the camera every frame, that places them at infinity
            // (no parallax against the body or against the stars).
            const skyPos = sunDir.clone().multiplyScalar(CONFIG.skyDistance);
            sunCore.position.copy(skyPos);
            sunHalo.position.copy(skyPos);
            chromaRing.position.copy(skyPos);
            sunStar.position.copy(skyPos);

            const coreScale  = CONFIG.sunSize * 2;
            sunCore.scale.setScalar(coreScale);
            sunHalo.scale.setScalar(coreScale * CONFIG.sunHaloScale);
            chromaRing.scale.setScalar(coreScale * CONFIG.chromaRingScale);
            sunStar.scale.setScalar(coreScale * CONFIG.sunStarScale);

            sunCore.visible   = CONFIG.showSun;
            sunHalo.visible   = CONFIG.showSun;
            chromaRing.visible = CONFIG.showSun;
            sunStar.visible    = CONFIG.showSun;
            sunHalo.material.opacity    = CONFIG.sunHaloOpacity;
            chromaRing.material.opacity = CONFIG.chromaRingOpacity;
            sunStar.material.opacity    = CONFIG.sunStarOpacity;

            ambient.intensity = CONFIG.ambientIntensity * CONFIG.sunIntensity;
            rim.intensity     = CONFIG.rimIntensity     * CONFIG.sunIntensity;
        }
        updateSun();

        // --- Per-frame flare placement / occlusion ----------------------------
        // Place each flare element at NDC = sunNDC * (1 - offset) so they
        // chain through screen centre, then unproject to a constant-depth
        // world point in front of the camera. Hidden when the sun is behind
        // the camera or off-screen; smoothly faded when the body covers the
        // sun (instead of popping on/off).
        const flareSunNdc      = new THREE.Vector3();
        const flareTmpPos      = new THREE.Vector3();
        const flareSunCamSpace = new THREE.Vector3();
        const flareCamToBody   = new THREE.Vector3();
        const flareCamToSun    = new THREE.Vector3();

        // EMA-smoothed visible fraction of the sun disc (0 = fully covered,
        // 1 = unobstructed). Driven by an analytical body-vs-sun disc
        // overlap each frame — no raycasts.
        const flareState = { visibility: 1 };

        // Area of intersection of two circles of radii r1, r2 whose centres
        // are `d` apart. Standard closed-form.
        function discOverlapArea(r1, r2, d) {
            if (d >= r1 + r2)            return 0;
            if (d <= Math.abs(r1 - r2))  return Math.PI * Math.min(r1, r2) ** 2;

            const r1sq = r1 * r1;
            const r2sq = r2 * r2;
            const a1 = r1sq * Math.acos((d * d + r1sq - r2sq) / (2 * d * r1));
            const a2 = r2sq * Math.acos((d * d + r2sq - r1sq) / (2 * d * r2));
            const a3 = 0.5 * Math.sqrt(
                Math.max(0,
                    (-d + r1 + r2) * (d + r1 - r2) * (d - r1 + r2) * (d + r1 + r2)
                ),
            );

            return a1 + a2 - a3;
        }

        // Analytical fraction of the sun disc that is NOT occluded by the
        // body, as seen from the camera right now. Treats the body as a
        // sphere of radius `planetRadius` centred at the world origin, the
        // sun as a sphere of radius `sunSize` at `skyDistance` along
        // `sunDir`. Both project to circles in the camera's angular field
        // of view; the visible fraction is `1 - overlap / sunArea`.
        // O(1), no raycasts — the previous sampled raycast loop was the
        // FPS killer.
        function measureSunVisibility(sunWorldPos) {
            flareCamToBody.set(0, 0, 0).sub(camera.position);
            const dBody = flareCamToBody.length();

            if (dBody <= CONFIG.planetRadius)
            {
                // Camera inside the body — pathological, treat as fully covered.
                return 0;
            }

            flareCamToSun.copy(sunWorldPos).sub(camera.position);
            const dSun = flareCamToSun.length();

            // Sun closer than the body to the camera can't be occluded by it.
            if (dSun <= dBody) return 1;

            const aBody = Math.asin(CONFIG.planetRadius / dBody);
            const aSun  = Math.asin(Math.min(1, CONFIG.sunSize / dSun));

            // Angular separation between body and sun as seen from camera.
            const cosSep = THREE.MathUtils.clamp(
                flareCamToBody.dot(flareCamToSun) / (dBody * dSun),
                -1, 1,
            );
            const sep = Math.acos(cosSep);

            const overlap = discOverlapArea(aBody, aSun, sep);
            const sunArea = Math.PI * aSun * aSun;

            return Math.max(0, 1 - overlap / sunArea);
        }

        function updateLensFlare(timeMs = 0) {
            const t = timeMs * 0.001;

            // The chroma ring and the starburst are always anchored on the
            // sun, so animate their rotation regardless of the rest of the
            // chain.
            chromaRing.material.rotation = t * deg2rad(CONFIG.chromaRingSpeed);
            sunStar.material.rotation    = t * deg2rad(CONFIG.sunStarSpeed);

            // Default: no flare elements visible until we know the sun is
            // on-screen and partly unobstructed.
            for (const f of flareElements) f.sprite.visible = false;

            if (!CONFIG.showSun)
            {
                flareState.visibility = 0;
                applySunDiscVisibility(0);

                return;
            }

            // Make sure camera matrices reflect any movement from this frame
            // (OrbitControls only sets the camera's local transform; matrixWorld
            // is normally updated lazily by the renderer).
            camera.updateMatrixWorld();

            // The visible sun is anchored under `skyAnchor` (which tracks the
            // camera), so compute its world position directly from the cached
            // sun direction and the current camera position.
            const sunWorldPos = flareTmpPos.copy(sunDir)
                .multiplyScalar(CONFIG.skyDistance)
                .add(camera.position);

            // Is the sun in front of the camera?
            flareSunCamSpace.copy(sunWorldPos).applyMatrix4(camera.matrixWorldInverse);
            const inFront = flareSunCamSpace.z < 0;

            // Project sun to NDC.
            flareSunNdc.copy(sunWorldPos).project(camera);
            const onScreen = inFront
                && Math.abs(flareSunNdc.x) <= 1.2
                && Math.abs(flareSunNdc.y) <= 1.2;

            // Analytical visible-disc fraction → EMA-smoothed. Gives a soft
            // cinematic fade-in when the body uncovers the sun, but hides
            // fast when the body crosses in front (`* 4` on the way down) so
            // the halo never lingers across the planet's silhouette.
            const measured = inFront ? measureSunVisibility(sunWorldPos) : 0;
            const ease     = measured < flareState.visibility
                ? Math.min(1, CONFIG.flareOcclusionEase * 4)
                : CONFIG.flareOcclusionEase;
            flareState.visibility += (measured - flareState.visibility) * ease;
            const vis = flareState.visibility;

            // Apply the smoothed visibility to the sun-disc elements (halo,
            // chroma ring, starburst). They keep their full base opacity at
            // vis=1, fade to nothing as vis → 0, so a body crossing the sun
            // gently dims the whole glow.
            applySunDiscVisibility(vis);

            if (!CONFIG.showLensFlare || !onScreen || vis < 0.01)
            {
                return;
            }

            // Fade as the sun approaches the edge of the viewport.
            const edgeDist = Math.max(Math.abs(flareSunNdc.x), Math.abs(flareSunNdc.y));
            const edgeFade = THREE.MathUtils.clamp(1 - (edgeDist - 0.7) / 0.5, 0, 1);
            // Subtle "punch up" near screen centre — real lenses flare hardest
            // when the source is dead-on the optical axis.
            const centreBoost = THREE.MathUtils.clamp(1 - flareSunNdc.length() * 0.5, 0.5, 1.1);
            // The chain's visibility curve is steeper than the disc's — a
            // partly-covered sun should kill the ghost chain quickly, but
            // let the halo linger.
            const chainVis    = vis * vis;
            const globalAlpha = CONFIG.lensFlareOpacity * edgeFade * centreBoost * chainVis;

            // Viewport height in world units at the "overlay" depth — used to
            // scale each flare so its `size` is a fraction of screen height.
            const overlayDepthNdc = 0.92; // close to near plane, drawn first
            flareTmpPos.set(0, 0, overlayDepthNdc).unproject(camera);
            const overlayDist = camera.position.distanceTo(flareTmpPos);
            const screenWorldHeight = 2 * overlayDist * Math.tan(deg2rad(camera.fov) / 2);

            for (let i = 0; i < flareElements.length; i++) {
                const f = flareElements[i];
                const ndcX = flareSunNdc.x * (1 - f.offset);
                const ndcY = flareSunNdc.y * (1 - f.offset);
                flareTmpPos.set(ndcX, ndcY, overlayDepthNdc).unproject(camera);
                f.sprite.position.copy(flareTmpPos);

                // Subtle scale & alpha pulse — each ghost has its own phase so
                // they don't all breathe in lock-step.
                const phase = i * 0.9;
                const breath = f.breath ?? 0.4;
                const wobble = Math.sin(t * 0.7 + phase) * 0.5 + 0.5; // 0..1
                const sizeMul  = 1 + (wobble - 0.5) * 0.12 * breath;
                const alphaMul = 1 + (wobble - 0.5) * 0.30 * breath;

                f.sprite.scale.setScalar(f.size * screenWorldHeight * sizeMul);
                f.sprite.material.opacity = f.alpha * globalAlpha * alphaMul;
                // Very slow counter-rotation on alternating ghosts — sells the
                // "iris artefact" feel without looking spun.
                f.sprite.material.rotation = (i % 2 === 0 ? 1 : -1) * t * 0.04 + i * 0.4;
                f.sprite.visible = globalAlpha > 0.01;
            }
        }

        // Apply the smoothed sun-visibility fraction to the on-sun elements.
        // Multiplies each one's *configured* base opacity, so the per-element
        // tuning in CONFIG remains authoritative.
        function applySunDiscVisibility(vis) {
            sunCore.material.opacity    = vis;
            sunHalo.material.opacity    = CONFIG.sunHaloOpacity    * Math.sqrt(Math.max(0, vis));
            chromaRing.material.opacity = CONFIG.chromaRingOpacity * vis;
            sunStar.material.opacity    = CONFIG.sunStarOpacity    * vis;
        }

        // Star field — a single Points object on a far sphere, rendered with a
        // tiny custom shader so each star can carry its own size and colour.
        //   * Colour is sampled from a Planckian (blackbody) curve to mimic
        //     the real stellar colour distribution: most stars look white /
        //     blue-white with a sprinkling of yellow, orange and red.
        //   * Size is power-law distributed: lots of small dots and a handful
        //     of bright giants.
        //   * Each star also has a brightness multiplier so they don't all
        //     pop at the same intensity.
        //
        // Tanner Helland's approximation gives a usable RGB for a colour
        // temperature in K. Good enough for a backdrop.
        function blackbodyRgb(kelvin) {
            const t = kelvin / 100;
            let r, g, b;

            if (t <= 66) {
                r = 255;
                g = 99.4708025861 * Math.log(t) - 161.1195681661;
            } else {
                r = 329.698727446 * Math.pow(t - 60, -0.1332047592);
                g = 288.1221695283 * Math.pow(t - 60, -0.0755148492);
            }

            if (t >= 66) {
                b = 255;
            } else if (t <= 19) {
                b = 0;
            } else {
                b = 138.5177312231 * Math.log(t - 10) - 305.0447927307;
            }

            const clamp01 = (v) => Math.max(0, Math.min(255, v)) / 255;

            return [clamp01(r), clamp01(g), clamp01(b)];
        }

        function buildStars() {
            const n = CONFIG.starCount;
            const positions = new Float32Array(n * 3);
            const colors    = new Float32Array(n * 3);
            const sizes     = new Float32Array(n);

            const tempRange = CONFIG.starTempMax - CONFIG.starTempMin;
            const sizeRange = CONFIG.starSizeMax - CONFIG.starSizeMin;
            const brightRange = CONFIG.starBrightnessMax - CONFIG.starBrightnessMin;
            const dpr = window.devicePixelRatio || 1;

            for (let i = 0; i < n; i++) {
                // Uniform direction on a sphere (z/φ method).
                const u = Math.random() * 2 - 1;
                const phi = Math.random() * Math.PI * 2;
                const s = Math.sqrt(1 - u * u);
                positions[i * 3]     = CONFIG.skyDistance * s * Math.cos(phi);
                positions[i * 3 + 1] = CONFIG.skyDistance * u;
                positions[i * 3 + 2] = CONFIG.skyDistance * s * Math.sin(phi);

                // Temperature with a bias toward the cool end of the range —
                // matches real spectral type distributions where M/K dwarfs
                // dominate. Inverted power so 0 → cool, 1 → hot.
                const tBias = 1 - Math.pow(Math.random(), 1 / CONFIG.starTempBias);
                const kelvin = CONFIG.starTempMin + tempRange * tBias;
                const [r, g, b] = blackbodyRgb(kelvin);

                // Brightness multiplier (uniform within the configured range).
                const brightness = CONFIG.starBrightnessMin + Math.random() * brightRange;
                colors[i * 3]     = r * brightness;
                colors[i * 3 + 1] = g * brightness;
                colors[i * 3 + 2] = b * brightness;

                // Size: heavy bias toward starSizeMin via a power-law roll, so
                // a small number of stars are notably bigger than the rest.
                // Multiply by DPR so the visual size is consistent on high-DPI
                // displays (gl_PointSize is in framebuffer pixels).
                const sizeRoll = Math.pow(Math.random(), CONFIG.starSizeBias);
                sizes[i] = (CONFIG.starSizeMin + sizeRange * sizeRoll) * dpr;
            }

            const geo = new THREE.BufferGeometry();
            geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            geo.setAttribute('aColor',   new THREE.BufferAttribute(colors, 3));
            geo.setAttribute('aSize',    new THREE.BufferAttribute(sizes, 1));

            const mat = new THREE.ShaderMaterial({
                transparent: true,
                depthWrite: false,
                vertexShader: `
                    attribute vec3 aColor;
                    attribute float aSize;
                    varying vec3 vColor;
                    void main() {
                        vColor = aColor;
                        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
                        gl_PointSize = aSize;
                    }
                `,
                fragmentShader: `
                    varying vec3 vColor;
                    void main() {
                        // Soft circular sprite — bright core, feathered edge.
                        vec2 c = gl_PointCoord - 0.5;
                        float d = length(c) * 2.0;
                        if (d > 1.0) discard;
                        float a = smoothstep(1.0, 0.15, d);
                        gl_FragColor = vec4(vColor, a);
                    }
                `,
            });

            return new THREE.Points(geo, mat);
        }
        const stars = buildStars();
        stars.visible = CONFIG.showStars;
        skyAnchor.add(stars);

        // ----------------------------------------------------------------------
        // Geometry helpers
        // ----------------------------------------------------------------------
        // `deg2rad` is hoisted above the lights block (it's needed by updateSun).

        function sphere(lonDeg, latDeg, r) {
            const lon = deg2rad(lonDeg);
            const lat = deg2rad(latDeg);
            const cl = Math.cos(lat);
            return new THREE.Vector3(
                r * cl * Math.cos(lon),
                r * Math.sin(lat),
                r * cl * Math.sin(lon),
            );
        }

        // Triangulation of the 6 faces of a quad (hexahedron) cell, indexed
        // into the 8 corners [A,B,C,D outer, E,F,G,H inner]. Wound so normals
        // face OUTWARD (FrontSide culling keeps the visible faces).
        const FACE_TRIS = [
            [0, 2, 1, 0, 3, 2], // 0: outer
            [4, 5, 6, 4, 6, 7], // 1: inner
            [0, 5, 4, 0, 1, 5], // 2: lat0 side
            [1, 6, 5, 1, 2, 6], // 3: lon1 side
            [2, 7, 6, 2, 3, 7], // 4: lat1 side
            [3, 4, 7, 3, 0, 4], // 5: lon0 side
        ];

        // the 12 edges of a quad cell hexahedron (corner index pairs)
        const CELL_EDGES = [
            [0, 1], [1, 2], [2, 3], [3, 0], // outer ring
            [4, 5], [5, 6], [6, 7], [7, 4], // inner ring
            [0, 4], [1, 5], [2, 6], [3, 7], // verticals
        ];

        // -------------------------------------------------------------------
        // Per-cell geometry generation.
        //
        // Each generator pushes raw vertex/normal/index data into the supplied
        // arrays so the same code can build either a standalone single-cell
        // geometry (for the hover overlay) or contribute to a merged
        // depth-layer mesh. Vertices are duplicated per face so each face
        // can carry its own normals — radial for outer/inner faces (gives
        // smooth shading across cell boundaries), flat for side faces.
        // -------------------------------------------------------------------
        function appendQuadCell(cell, positions, normals, indices) {
            const corners = cell.corners;
            const vertBase = positions.length / 3;

            for (let f = 0; f < 6; f++) {
                const tris = FACE_TRIS[f];

                // Flat face normal for side/inner faces.
                const a = corners[tris[0]], b = corners[tris[1]], c = corners[tris[2]];
                const e1x = b.x - a.x, e1y = b.y - a.y, e1z = b.z - a.z;
                const e2x = c.x - a.x, e2y = c.y - a.y, e2z = c.z - a.z;
                let nx = e1y * e2z - e1z * e2y;
                let ny = e1z * e2x - e1x * e2z;
                let nz = e1x * e2y - e1y * e2x;
                const nl = Math.hypot(nx, ny, nz) || 1;
                nx /= nl; ny /= nl; nz /= nl;

                for (let t = 0; t < 6; t++) {
                    const p = corners[tris[t]];
                    positions.push(p.x, p.y, p.z);

                    if (f === 0) {
                        // Outer face: radial outward — shared across neighbours.
                        const len = Math.hypot(p.x, p.y, p.z) || 1;
                        normals.push(p.x / len, p.y / len, p.z / len);
                    } else if (f === 1) {
                        // Inner face: radial inward.
                        const len = Math.hypot(p.x, p.y, p.z) || 1;
                        normals.push(-p.x / len, -p.y / len, -p.z / len);
                    } else {
                        normals.push(nx, ny, nz);
                    }

                    indices.push(vertBase + f * 6 + t);
                }
            }
        }

        function appendCapCell(cell, positions, normals, indices) {
            const { boundaryLat, rOuter, rInner, sign, fan } = cell;
            const rings = Math.max(2, CONFIG.polarCapRings ?? 4);
            const poleLat = sign * 90;

            // Pre-sample concentric rings between the pole (i = 0) and the cap
            // boundary (i = rings) at both crust radii. Sampling the latitudes
            // on the real sphere is what rounds the silhouette — a single
            // pole→ring fan would still draw a cone.
            const outerRings = [];
            const innerRings = [];

            for (let i = 0; i <= rings; i++) {
                const t = i / rings;
                const lat = poleLat + (boundaryLat - poleLat) * t;
                const ringO = new Array(fan);
                const ringI = new Array(fan);

                for (let k = 0; k < fan; k++) {
                    const lon = (k / fan) * 360;
                    ringO[k] = sphere(lon, lat, rOuter);
                    ringI[k] = sphere(lon, lat, rInner);
                }

                outerRings.push(ringO);
                innerRings.push(ringI);
            }

            // Outer skin: quad strip between ring i and ring i+1, radial-outward
            // normals so shading is continuous across both rings *and* across
            // the boundary into the surrounding quad cells.
            for (let i = 0; i < rings; i++)
            {
                const r0 = outerRings[i];
                const r1 = outerRings[i + 1];

                for (let k = 0; k < fan; k++)
                {
                    const k2 = (k + 1) % fan;
                    const a = r0[k], b = r0[k2], c = r1[k2], d = r1[k];
                    // Winding matches the original outer fan (pole, ring[k2], ring[k])
                    // for sign>0 and the swapped variant for sign<0.
                    const verts = sign > 0
                        ? [a, b, c, a, c, d]
                        : [a, d, c, a, c, b];
                    const base = positions.length / 3;

                    for (const p of verts) pushRadial(positions, normals, p, 1);

                    indices.push(base, base + 1, base + 2, base + 3, base + 4, base + 5);
                }
            }

            // Inner skin: same strips, inward normals, reversed winding.
            for (let i = 0; i < rings; i++)
            {
                const r0 = innerRings[i];
                const r1 = innerRings[i + 1];

                for (let k = 0; k < fan; k++)
                {
                    const k2 = (k + 1) % fan;
                    const a = r0[k], b = r0[k2], c = r1[k2], d = r1[k];
                    const verts = sign > 0
                        ? [a, d, c, a, c, b]
                        : [a, b, c, a, c, d];
                    const base = positions.length / 3;

                    for (const p of verts) pushRadial(positions, normals, p, -1);

                    indices.push(base, base + 1, base + 2, base + 3, base + 4, base + 5);
                }
            }

            // Boundary cone wall: quad strip between outer and inner rings at
            // the cap boundary, flat outward normals per segment. Unchanged
            // from the original implementation — just sourced from the last
            // subdivision ring.
            const ringOuter = outerRings[rings];
            const ringInner = innerRings[rings];

            for (let k = 0; k < fan; k++) {
                const k2 = (k + 1) % fan;
                const a = ringOuter[k];
                const b = ringOuter[k2];
                const c = ringInner[k2];
                const d = ringInner[k];

                // Outward direction at the segment midpoint (away from the
                // rotation axis).
                const mx = (a.x + b.x + c.x + d.x) / 4;
                const mz = (a.z + b.z + c.z + d.z) / 4;
                const ml = Math.hypot(mx, mz) || 1;
                const outX = mx / ml, outZ = mz / ml;

                // Compute the face normal from a candidate winding and flip if
                // it points the wrong way.
                let e1x = b.x - a.x, e1y = b.y - a.y, e1z = b.z - a.z;
                let e2x = d.x - a.x, e2y = d.y - a.y, e2z = d.z - a.z;
                let nx = e1y * e2z - e1z * e2y;
                let ny = e1z * e2x - e1x * e2z;
                let nz = e1x * e2y - e1y * e2x;
                const nl = Math.hypot(nx, ny, nz) || 1;
                nx /= nl; ny /= nl; nz /= nl;
                const flip = (nx * outX + nz * outZ) < 0;

                if (flip) { nx = -nx; ny = -ny; nz = -nz; }

                const winding = flip ? [a, c, b, a, d, c] : [a, b, c, a, c, d];
                const base = positions.length / 3;

                for (const p of winding) {
                    positions.push(p.x, p.y, p.z);
                    normals.push(nx, ny, nz);
                }

                indices.push(base, base + 1, base + 2, base + 3, base + 4, base + 5);
            }
        }

        // Push a vertex with a radial normal scaled by `dir` (+1 outward, -1 inward).
        function pushRadial(positions, normals, p, dir) {
            positions.push(p.x, p.y, p.z);
            const len = Math.hypot(p.x, p.y, p.z) || 1;
            normals.push(dir * p.x / len, dir * p.y / len, dir * p.z / len);
        }

        function appendCellToBuffers(cell, positions, normals, indices) {
            const triStart = indices.length / 3;

            if (cell.kind === 'cap') {
                appendCapCell(cell, positions, normals, indices);
            } else {
                appendQuadCell(cell, positions, normals, indices);
            }

            cell.triCount = indices.length / 3 - triStart;
        }

        // Build a standalone BufferGeometry for ONE cell (used by the hover/
        // selection overlay). Not used for the main rendered body.
        function buildSingleCellGeometry(cell) {
            const positions = [], normals = [], indices = [];
            appendCellToBuffers(cell, positions, normals, indices);
            const geo = new THREE.BufferGeometry();
            geo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
            geo.setAttribute('normal', new THREE.Float32BufferAttribute(normals, 3));
            geo.setIndex(indices);
            geo.computeBoundingSphere();
            return geo;
        }

        // ----------------------------------------------------------------------
        // Clipping plane (used only in resource mode)
        // ----------------------------------------------------------------------
        const clipPlane = new THREE.Plane(new THREE.Vector3(0, -1, 0), 0);

        // ----------------------------------------------------------------------
        // Build the body
        // ----------------------------------------------------------------------
        const bodyGroup = new THREE.Group();
        scene.add(bodyGroup);

        // shared materials (one per depth) -> cheap clipping toggle
        const depthMaterials = depthColors.map((c, d) => new THREE.MeshStandardMaterial({
            color: c,
            roughness: 0.95,
            metalness: 0.0,
            // single-sided: coincident walls of touching cells have opposite
            // normals, so back-face culling leaves only one -> no z-fighting.
            side: THREE.FrontSide,
            // deeper layers are slightly emissive so the cross-section reads well
            emissive: new THREE.Color(c).multiplyScalar(0.06 * d),
        }));

        // core — sized to exactly fill the deepest cell's inner radius so it
        // touches the bottom of the crust with no annular gap on the cut
        // plane. View mode hides the sub-surface layers (see `applyClipping`)
        // so the core's outer surface is never visible through them — no
        // z-fighting concern. In resource mode the clip plane is the only
        // place the core meets the crust, and the disc cap below shares the
        // same radius, so the cross-section reads as continuous.
        const core = new THREE.Mesh(
            new THREE.SphereGeometry(coreRadius, 96, 64),
            new THREE.MeshStandardMaterial({ color: CONFIG.coreColor, roughness: 1, side: THREE.DoubleSide }),
        );
        bodyGroup.add(core);

        // ------------------------------------------------------------------
        // Atmosphere shell
        //
        // A back-face-rendered sphere wrapped around the planet, slightly
        // larger than `planetRadius`. The fragment shader walks the view
        // ray through the atmosphere shell, sampling Rayleigh + Mie
        // scattering and the in-scattered light from the sun direction.
        //
        // The classic glsl-atmosphere single-scattering integrator (Sean
        // O'Neil-style) is used here, but scaled down to scene units and
        // re-parameterised so every knob is exposed via CONFIG above. The
        // sample counts are tiny (8 view × 4 light by default) because the
        // shell is thin and we only render its back faces — the planet's
        // own depth occludes the half facing the camera, so only the limb
        // glow survives, which is exactly the look we want.
        // ------------------------------------------------------------------
        const atmosphereRadius = CONFIG.planetRadius * (1 + CONFIG.atmosphereThickness);
        const atmosphereShellH = atmosphereRadius - CONFIG.planetRadius;

        atmosphereUniforms = {
            uPlanetRadius:   { value: CONFIG.planetRadius },
            uAtmosRadius:    { value: atmosphereRadius },
            uSunDir:         { value: new THREE.Vector3(1, 0, 0) },
            uSunIntensity:   { value: CONFIG.atmosphereSunIntensity },
            uOpacity:        { value: CONFIG.atmosphereOpacity },
            uBaseColor:      { value: new THREE.Vector3(...CONFIG.atmosphereBaseColor) },
            uRayleighCoeff:  { value: new THREE.Vector3(...CONFIG.atmosphereRayleighCoeff) },
            // Scale heights are fractions of the shell thickness so the
            // density profile is sensible regardless of `atmosphereThickness`.
            uRayleighScale:  { value: atmosphereShellH * CONFIG.atmosphereRayleighScaleFrac },
            uMieCoeff:       { value: CONFIG.atmosphereMieCoeff },
            uMieScale:       { value: atmosphereShellH * CONFIG.atmosphereMieScaleFrac },
            uMieG:           { value: CONFIG.atmosphereMieG },
            uPlanetCenter:   { value: new THREE.Vector3(0, 0, 0) },
        };

        const atmosphereMaterial = new THREE.ShaderMaterial({
            uniforms: atmosphereUniforms,
            transparent: true,
            side: THREE.FrontSide,
            // Additive blending so the rim glow accumulates onto the sky /
            // planet behind it rather than overwriting them. Front-side
            // rendering means the shell also draws *over* the planet's disc
            // (the shader stops the ray-march at the planet surface), so
            // the atmospheric haze continuously stretches from the limb all
            // the way down to the ground on the day side.
            blending: THREE.AdditiveBlending,
            depthWrite: false,
            depthTest: true,
            defines: {
                I_STEPS: CONFIG.atmosphereViewSteps | 0,
                J_STEPS: CONFIG.atmosphereLightSteps | 0,
            },
            vertexShader: /* glsl */`
                varying vec3 vWorldPos;
                void main() {
                    vec4 wp = modelMatrix * vec4(position, 1.0);
                    vWorldPos = wp.xyz;
                    gl_Position = projectionMatrix * viewMatrix * wp;
                }
            `,
            fragmentShader: /* glsl */`
                precision highp float;

                varying vec3 vWorldPos;

                uniform vec3  uPlanetCenter;
                uniform float uPlanetRadius;
                uniform float uAtmosRadius;
                uniform vec3  uSunDir;
                uniform float uSunIntensity;
                uniform float uOpacity;
                uniform vec3  uBaseColor;
                uniform vec3  uRayleighCoeff;
                uniform float uRayleighScale;
                uniform float uMieCoeff;
                uniform float uMieScale;
                uniform float uMieG;

                const float PI = 3.141592653589793;

                // Ray / sphere intersection. Returns the two ray parameters
                // (entry, exit) — or (1e9, -1e9) if the ray misses.
                vec2 raySphere(vec3 ro, vec3 rd, float sr) {
                    float b = dot(rd, ro);
                    float c = dot(ro, ro) - sr * sr;
                    float d = b * b - c;
                    if (d < 0.0) return vec2(1e9, -1e9);
                    d = sqrt(d);
                    return vec2(-b - d, -b + d);
                }

                vec3 atmosphere(vec3 r, vec3 r0, vec3 pSun) {
                    // Bring everything into planet-local space so the sphere
                    // tests are centred at the origin.
                    r0 = r0 - uPlanetCenter;

                    // The base colour multiplies the *physical* Rayleigh
                    // coefficient — it isn't just a final tint. That keeps
                    // the wavelength-dependent attenuation intact, which is
                    // what produces the warm red/orange limb at the
                    // terminator (long sight-paths scatter blue out, leaving
                    // red to reach the eye — Earth's sunsets). A neutral
                    // [1,1,1] base colour therefore produces a literally
                    // colourless atmosphere with no terminator reddening,
                    // exactly as expected for a grey scattering medium.
                    vec3 rayleighEff = uRayleighCoeff * uBaseColor;

                    vec2 p = raySphere(r0, r, uAtmosRadius);
                    if (p.x > p.y) return vec3(0.0);

                    // Stop at the planet surface (if hit) so we don't sample
                    // "through" the body.
                    vec2 pp = raySphere(r0, r, uPlanetRadius);
                    if (pp.x > 0.0) p.y = min(p.y, pp.x);
                    p.x = max(p.x, 0.0);

                    float iStepSize = (p.y - p.x) / float(I_STEPS);
                    float iTime = p.x;

                    vec3  totalRlh = vec3(0.0);
                    vec3  totalMie = vec3(0.0);
                    float iOdRlh   = 0.0;
                    float iOdMie   = 0.0;

                    float mu   = dot(r, pSun);
                    float mumu = mu * mu;
                    float gg   = uMieG * uMieG;

                    // Rayleigh phase: 3/(16π)·(1+μ²)
                    float pRlh = 3.0 / (16.0 * PI) * (1.0 + mumu);
                    // Henyey–Greenstein phase for Mie (forward-scattering).
                    float pMie = 3.0 / (8.0 * PI)
                               * ((1.0 - gg) * (mumu + 1.0))
                               / (pow(1.0 + gg - 2.0 * mu * uMieG, 1.5) * (2.0 + gg));

                    for (int i = 0; i < I_STEPS; i++) {
                        vec3  iPos    = r0 + r * (iTime + iStepSize * 0.5);
                        float iHeight = length(iPos) - uPlanetRadius;

                        float odStepRlh = exp(-iHeight / uRayleighScale) * iStepSize;
                        float odStepMie = exp(-iHeight / uMieScale)      * iStepSize;
                        iOdRlh += odStepRlh;
                        iOdMie += odStepMie;

                        // March from this sample toward the sun to gather the
                        // optical depth seen by inbound sunlight.
                        float jStepSize = raySphere(iPos, pSun, uAtmosRadius).y / float(J_STEPS);
                        float jTime     = 0.0;
                        float jOdRlh    = 0.0;
                        float jOdMie    = 0.0;

                        for (int j = 0; j < J_STEPS; j++) {
                            vec3  jPos    = iPos + pSun * (jTime + jStepSize * 0.5);
                            float jHeight = length(jPos) - uPlanetRadius;
                            jOdRlh += exp(-jHeight / uRayleighScale) * jStepSize;
                            jOdMie += exp(-jHeight / uMieScale)      * jStepSize;
                            jTime  += jStepSize;
                        }

                        vec3 attn = exp(-(uMieCoeff * (iOdMie + jOdMie)
                                       + rayleighEff * (iOdRlh + jOdRlh)));

                        totalRlh += odStepRlh * attn;
                        totalMie += odStepMie * attn;
                        iTime    += iStepSize;
                    }

                    return uSunIntensity * (pRlh * rayleighEff * totalRlh
                                          + pMie * uMieCoeff   * totalMie);
                }

                void main() {
                    vec3 viewDir = normalize(vWorldPos - cameraPosition);
                    vec3 col = atmosphere(viewDir, cameraPosition, normalize(uSunDir));

                    // (The base-colour tint is already baked into the
                    // scattering coefficients inside the atmosphere()
                    // integration above, so it correctly affects both the
                    // in-scattering AND the wavelength-dependent attenuation
                    // that produces the red/orange terminator. No extra
                    // post-tint here.)

                    // Soft tonemap so very bright fragments near the sun
                    // don't blow out to pure white.
                    col = 1.0 - exp(-col);
                    col *= uOpacity;

                    // Additive blending with srcAlpha=1 — the color itself
                    // carries the intensity. Multiplying by a small alpha
                    // here would dim the rim glow into invisibility.
                    gl_FragColor = vec4(col, 1.0);
                }
            `,
        });

        const atmosphereMesh = new THREE.Mesh(
            new THREE.SphereGeometry(atmosphereRadius, 96, 64),
            atmosphereMaterial,
        );
        atmosphereMesh.visible = CONFIG.showAtmosphere;
        // Render after the planet so depth-test against the body works.
        atmosphereMesh.renderOrder = 1;
        bodyGroup.add(atmosphereMesh);

        // Now that the atmosphere uniforms exist, refresh the sun bindings
        // so `uSunIntensity` picks up the correct initial value (the first
        // `updateSun()` call during init ran before this block existed).
        updateSun();

        // ------------------------------------------------------------------
        // Body construction — ONE merged BufferGeometry per depth layer.
        //
        // Cells can have variable triangle counts (quad cells = 12 tris, polar
        // cap cells depend on `capFan`), so each merged mesh carries a
        // `faceToCell` lookup table to map a raycast `faceIndex` back to its
        // owning cell.
        // ------------------------------------------------------------------
        const cells = [];                              // flat metadata, all cells
        const cellsByDepth = [];                       // cellsByDepth[d] = array of cells in that depth
        const depthMeshes = [];                        // one merged Mesh per depth

        for (let d = 0; d < maxDepth; d++) {
            cellsByDepth[d] = [];

            const positions = [];
            const normals = [];
            const indices = [];
            const faceToCell = [];

            const rOuter = layerRadii[d];
            const rInner = layerRadii[d + 1];

            // --- Quad cells (the non-cap latitude band) -------------------
            for (let j = capRows; j < CONFIG.latCells - capRows; j++) {
                const lat0 = -90 + j * rowDegLat;
                const lat1 = -90 + (j + 1) * rowDegLat;

                for (let i = 0; i < CONFIG.lonCells; i++) {
                    const lon0 = (i / CONFIG.lonCells) * 360;
                    const lon1 = ((i + 1) / CONFIG.lonCells) * 360;

                    const corners = [
                        sphere(lon0, lat0, rOuter), sphere(lon1, lat0, rOuter),
                        sphere(lon1, lat1, rOuter), sphere(lon0, lat1, rOuter),
                        sphere(lon0, lat0, rInner), sphere(lon1, lat0, rInner),
                        sphere(lon1, lat1, rInner), sphere(lon0, lat1, rInner),
                    ];

                    const cell = {
                        kind: 'quad',
                        lon: (lon0 + lon1) / 2,
                        lat: (lat0 + lat1) / 2,
                        depth: d,
                        lonIdx: i,
                        latIdx: j,
                        corners,
                        geom: null,
                        edges: null,
                    };

                    addCellToDepth(cell);
                }
            }

            // --- Polar cap cells (one per pole, when enabled) -------------
            if (capRows > 0) {
                for (const sign of [+1, -1]) {
                    const boundaryLat = sign > 0 ? capBoundaryLatN : capBoundaryLatS;
                    const cell = {
                        kind: 'cap',
                        sign,
                        boundaryLat,
                        rOuter,
                        rInner,
                        fan: capFan,
                        // Used by the readout / camera anchoring.
                        lon: 0,
                        lat: sign * (90 - capRows * rowDegLat / 2),
                        depth: d,
                        geom: null,
                        edges: null,
                    };

                    addCellToDepth(cell);
                }
            }

            const geo = new THREE.BufferGeometry();
            geo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
            geo.setAttribute('normal', new THREE.Float32BufferAttribute(normals, 3));
            geo.setIndex(indices);
            geo.computeBoundingSphere();

            const mesh = new THREE.Mesh(geo, depthMaterials[d]);
            mesh.userData.depth = d;
            mesh.userData.faceToCell = faceToCell;
            // Sub-surface cells are fully occluded by the surface in view mode.
            if (d > 0) mesh.visible = false;
            bodyGroup.add(mesh);
            depthMeshes.push(mesh);

            function addCellToDepth(cell) {
                cells.push(cell);
                cellsByDepth[d].push(cell);

                const triStart = indices.length / 3;
                appendCellToBuffers(cell, positions, normals, indices);

                for (let t = triStart; t < indices.length / 3; t++) {
                    faceToCell.push(cell);
                }
            }
        }

        // Recover the cell record from a raycast hit on a merged body mesh.
        function cellFromBodyHit(hit) {
            return hit.object.userData.faceToCell[hit.faceIndex];
        }

        // ------------------------------------------------------------------
        // Analytical surface picking (view mode).
        //
        // The depth-0 merged mesh has ~lonCells*latCells*12 triangles
        // (~125k at default settings). Three.js' raycaster has no BVH and
        // tests every triangle linearly whenever the ray hits the planet's
        // bounding sphere — that's the FPS sink while the cursor is over
        // the body. Same idea as `measureSunVisibility` above: replace the
        // per-frame raycast loop with a closed-form ray-vs-sphere
        // intersection, then index straight into the cell grid.
        //
        // Surface cells live at radius `planetRadius`, the body is centred
        // at the world origin, so this is O(1) regardless of grid density.
        // Resource mode keeps the raycast path because the cap caps carry
        // arbitrary cut geometry that isn't a sphere.
        // ------------------------------------------------------------------
        const surfaceQuadLookup = new Array(CONFIG.latCells * CONFIG.lonCells).fill(null);
        let surfaceCapNorth = null;
        let surfaceCapSouth = null;

        for (const cell of cellsByDepth[0])
        {
            if (cell.kind === 'quad')
            {
                surfaceQuadLookup[cell.latIdx * CONFIG.lonCells + cell.lonIdx] = cell;
            }
            else if (cell.sign > 0)
            {
                surfaceCapNorth = cell;
            }
            else
            {
                surfaceCapSouth = cell;
            }
        }

        const _pickHit = new THREE.Vector3();
        const rad2deg = 180 / Math.PI;

        function pickSurfaceCellAnalytical() {
            // raycaster.ray.{origin,direction} are already set by the caller.
            const o = raycaster.ray.origin;
            const d = raycaster.ray.direction;
            const R = CONFIG.planetRadius;

            // Solve |o + t*d|^2 = R^2  =>  t^2 + 2(o.d)t + (o.o - R^2) = 0
            // (d is unit-length, so the leading coefficient is 1.)
            const b = o.dot(d);
            const c = o.dot(o) - R * R;
            const disc = b * b - c;

            if (disc < 0) return null;

            const sq = Math.sqrt(disc);
            let t = -b - sq;
            if (t < 0) t = -b + sq;
            if (t < 0) return null;

            _pickHit.copy(d).multiplyScalar(t).add(o);

            const latDeg = Math.asin(THREE.MathUtils.clamp(_pickHit.y / R, -1, 1)) * rad2deg;
            let lonDeg = Math.atan2(_pickHit.z, _pickHit.x) * rad2deg;
            if (lonDeg < 0) lonDeg += 360;

            const j = Math.floor((latDeg + 90) / rowDegLat);

            if (j < capRows)                      return surfaceCapSouth;
            if (j >= CONFIG.latCells - capRows)   return surfaceCapNorth;

            let i = Math.floor(lonDeg / 360 * CONFIG.lonCells);
            if (i < 0)                  i = 0;
            if (i >= CONFIG.lonCells)   i = CONFIG.lonCells - 1;

            return surfaceQuadLookup[j * CONFIG.lonCells + i];
        }

        // Lazy per-cell geometry for the hover/selection overlay.
        function getCellGeom(cell) {
            if (!cell.geom) cell.geom = buildSingleCellGeometry(cell);
            return cell.geom;
        }

        function getCellEdges(cell) {
            if (!cell.edges) {
                // Cap cells fan out into many small tris that share smooth
                // radial normals; a low EdgesGeometry threshold would draw
                // every fan crease. Use a higher threshold so only the cap
                // boundary ring shows up as an outline.
                const thresh = cell.kind === 'cap' ? 30 : 1;
                cell.edges = new THREE.EdgesGeometry(getCellGeom(cell), thresh);
            }
            return cell.edges;
        }

        // ------------------------------------------------------------------
        // Resource-mode highlight geometry.
        //
        // The cached `getCellGeom()` builds the FULL 6-face hexahedron, which
        // is what view mode wants (only the outer face is visible there
        // because the deeper layers are hidden). In resource mode the user
        // sees the cell carved open by the meridian clip plane, and the full
        // hex would extend half-way through the visible cross-section,
        // producing the "highlight clips through the cell" artefact.
        //
        // Instead we emit a minimal mesh covering only what's *visible*:
        //   - depth 0:  the outer (sphere-surface) face PLUS the cross-section
        //               face on the cut plane (camera-facing).
        //   - depth >0: the cross-section face on the cut plane only.
        //
        // The cross-section depends on the current `clipPlane`, so this is
        // recomputed on every hover change — the geometry is small enough
        // (≤ a few triangles) that there's no benefit to caching.
        // ------------------------------------------------------------------
        function buildResourceHighlightGeometry(cell) {
            const positions = [];
            const normals = [];
            const indices = [];

            // (a) Cross-section face on the clip plane. Lifted slightly off
            // the cap (same direction as buildCaps' own lift) so the
            // highlight wins the depth test against the cap underneath.
            const cross = cellCrossSection(cell);

            if (cross !== null)
            {
                const n = clipPlane.normal;
                const lift = CONFIG.planetRadius * 0.0015;
                const base = positions.length / 3;

                for (const p of cross.positions)
                {
                    positions.push(p.x - n.x * lift, p.y - n.y * lift, p.z - n.z * lift);
                    normals.push(-n.x, -n.y, -n.z);
                }

                for (const i of cross.indices)
                {
                    indices.push(base + i);
                }
            }

            // (b) On the surface layer, also include the outer face so the
            // highlight reads as a corner wrapping over the top edge of the
            // cliff:
            //   - quad cells: a single quad (two tris) at the sphere surface.
            //   - cap cells: the whole pole dome — every fan-strip
            //     triangle of the cap's outer skin, so the entire polar cap
            //     lights up.
            //
            // No geometric out-multiplier is used; the highlight material's
            // polygonOffset handles z-fighting against the surface mesh.
            // (An earlier `out = 1.0008` multiplier lifted the face along
            // the radial, which read as a perspective-dependent screen
            // drift when you looked at it from an oblique angle.)
            if (cell.depth === 0 && cell.kind === 'quad')
            {
                const corners = cell.corners;
                const tris = FACE_TRIS[0]; // outer face = [0, 2, 1, 0, 3, 2]
                const base = positions.length / 3;

                for (let t = 0; t < 6; t++)
                {
                    const p = corners[tris[t]];
                    const len = Math.hypot(p.x, p.y, p.z) || 1;
                    positions.push(p.x, p.y, p.z);
                    normals.push(p.x / len, p.y / len, p.z / len);
                    indices.push(base + t);
                }
            }
            else if (cell.depth === 0 && cell.kind === 'cap')
            {
                appendCapOuterSkin(cell, positions, normals, indices);
            }

            const geo = new THREE.BufferGeometry();
            geo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
            geo.setAttribute('normal', new THREE.Float32BufferAttribute(normals, 3));
            geo.setIndex(indices);
            geo.computeBoundingSphere();

            return geo;
        }

        // Outer skin of a polar cap cell — same sampling pattern as the
        // dome section of `appendCapCell`. Used by the surface highlight
        // so that hovering a polar cap lights up the entire pole, not
        // just the cross-section sliver.
        function appendCapOuterSkin(cell, positions, normals, indices) {
            const { boundaryLat, rOuter, sign, fan } = cell;
            const rings = Math.max(2, CONFIG.polarCapRings ?? 4);
            const poleLat = sign * 90;
            // In resource mode the cap is clipped by the meridian plane; the
            // visible half-dome is the side on the camera's half-space
            // (where dot(n, p) <= 0, since clipping rejects the > 0 side).
            // Filter each fan triangle by its centroid so the highlight
            // covers the half-circle the user actually sees, not the full
            // pole. The epsilon keeps triangles whose centroid sits exactly
            // on the seam on the visible side, so the half-dome edge meets
            // the cross-section without a one-triangle gap.
            const n = clipPlane.normal;
            const planeK = clipPlane.constant;
            const eps = 1e-3;
            const outerRings = [];
            for (let i = 0; i <= rings; i++)
            {
                const t = i / rings;
                const lat = poleLat + (boundaryLat - poleLat) * t;
                const ring = new Array(fan);
                for (let j = 0; j < fan; j++)
                {
                    ring[j] = sphere((j / fan) * 360, lat, rOuter);
                }
                outerRings.push(ring);
            }
            for (let i = 0; i < rings; i++)
            {
                const r0 = outerRings[i];
                const r1 = outerRings[i + 1];
                for (let j = 0; j < fan; j++)
                {
                    const j2 = (j + 1) % fan;
                    const a = r0[j], b = r0[j2], c = r1[j2], d = r1[j];
                    const verts = sign > 0
                        ? [a, b, c, a, c, d]
                        : [a, d, c, a, c, b];
                    // Two triangles per quad strip cell; filter each by
                    // centroid against the clip plane.
                    for (let tri = 0; tri < 2; tri++)
                    {
                        const v0 = verts[tri * 3];
                        const v1 = verts[tri * 3 + 1];
                        const v2 = verts[tri * 3 + 2];
                        const cx = (v0.x + v1.x + v2.x) / 3;
                        const cy = (v0.y + v1.y + v2.y) / 3;
                        const cz = (v0.z + v1.z + v2.z) / 3;
                        // Three.js clipping discards fragments where
                        // dot(n, p) + k < 0, so the visible half-space is
                        // dot >= 0. Skip triangles on the OTHER side (the
                        // clipped half), which is what the user sees as
                        // "the planet"; keep the rest so the highlight
                        // overlays the visible half-dome on the surface.
                        if (n.x * cx + n.y * cy + n.z * cz + planeK < -eps)
                        {
                            continue; // clipped (hidden) half
                        }
                        const base = positions.length / 3;
                        for (const p of [v0, v1, v2])
                        {
                            positions.push(p.x, p.y, p.z);
                            const len = Math.hypot(p.x, p.y, p.z) || 1;
                            normals.push(p.x / len, p.y / len, p.z / len);
                        }
                        indices.push(base, base + 1, base + 2);
                    }
                }
            }
        }

        // ----------------------------------------------------------------------
        // Grid lines (lon/lat) drawn on the surface
        // ----------------------------------------------------------------------
        function buildGrid() {
            const pts = [];
            const STEP = 4; // sampling density of each line
            const rr = CONFIG.planetRadius + 0.05;

            // Lat range covered by the quad grid (everything outside is a cap).
            const latMin = -90 + capRows * rowDegLat;
            const latMax =  90 - capRows * rowDegLat;

            // longitude lines (stop at the cap boundary instead of running into
            // the pole, where they'd all converge into a useless tangle).
            for (let i = 0; i < CONFIG.lonCells; i++) {
                const lon = (i / CONFIG.lonCells) * 360;
                for (let lat = latMin; lat < latMax; lat += STEP) {
                    const lat2 = Math.min(lat + STEP, latMax);
                    pts.push(sphere(lon, lat, rr), sphere(lon, lat2, rr));
                }
            }
            // latitude lines (rings) — only those within the non-cap band,
            // including the cap boundary rings themselves.
            for (let j = capRows; j <= CONFIG.latCells - capRows; j++) {
                const lat = -90 + j * rowDegLat;
                for (let lon = 0; lon < 360; lon += STEP) {
                    pts.push(sphere(lon, lat, rr), sphere(lon + STEP, lat, rr));
                }
            }

            const geo = new THREE.BufferGeometry().setFromPoints(pts);
            const mat = new THREE.LineBasicMaterial({ color: CONFIG.gridColor, transparent: true, opacity: 0.55 });
            return new THREE.LineSegments(geo, mat);
        }
        // Surface-only target for view-mode picking: just the depth-0 merged mesh.
        const surfaceMeshes = [depthMeshes[0]];

        const grid = buildGrid();
        // The grid mesh is kept around (handy for debugging) but stays hidden
        // by default — the per-cell hover highlight is what reveals the cell
        // structure on demand. Without this, every cell boundary draws a faint
        // dark line that reads as a "seam" between cells.
        grid.visible = false;
        bodyGroup.add(grid);

        // ----------------------------------------------------------------------
        // Hover highlight (re-uses the hovered cell's geometry)
        // ----------------------------------------------------------------------
        const highlight = new THREE.Mesh(
            new THREE.BufferGeometry(),
            new THREE.MeshBasicMaterial({
                color: 0xfff2a0, transparent: true, opacity: 0.35, side: THREE.DoubleSide,
                depthWrite: false, polygonOffset: true, polygonOffsetFactor: -2, polygonOffsetUnits: -2,
            }),
        );
        highlight.visible = false;
        scene.add(highlight);

        const highlightEdges = new THREE.LineSegments(
            new THREE.BufferGeometry(),
            new THREE.LineBasicMaterial({ color: 0xffe66b }),
        );
        highlightEdges.visible = false;
        scene.add(highlightEdges);

        // ----------------------------------------------------------------------
        // Slice plane visual (shows where the body is cut in resource mode)
        // ----------------------------------------------------------------------
        const sliceVisual = new THREE.Mesh(
            new THREE.PlaneGeometry(CONFIG.planetRadius * 2.6, CONFIG.planetRadius * 2.6),
            new THREE.MeshBasicMaterial({
                color: 0x4f8bff, transparent: true, opacity: 0.12,
                side: THREE.DoubleSide, depthWrite: false,
            }),
        );
        sliceVisual.visible = false;
        scene.add(sliceVisual);

        // ----------------------------------------------------------------------
        // Cut caps — flat polygons that close each sliced cell at the plane, so
        // the cut looks solid and stays LEVEL with the slice plane (the cells are
        // really cut by the plane, not hidden). One cap mesh per sliced cell,
        // carrying the cell's coordinates so the cross-section stays clickable.
        // ----------------------------------------------------------------------
        const capMaterials = depthColors.map((c) => new THREE.MeshStandardMaterial({
            color: new THREE.Color(c).multiplyScalar(0.85),
            roughness: 1, metalness: 0, side: THREE.DoubleSide,
        }));
        const coreCapMaterial = new THREE.MeshStandardMaterial({
            color: CONFIG.coreColor, roughness: 1, side: THREE.DoubleSide,
        });
        const capsGroup = new THREE.Group();
        scene.add(capsGroup);
        const capMeshes = [];

        // ----------------------------------------------------------------------
        // State
        // ----------------------------------------------------------------------
        const state = {
            mode: 'view',           // 'view' | 'resource'
            selected: null,         // selected SURFACE cell userData (gates resource mode)
            focus: { lon: 0, lat: 0, lonTarget: 0, latTarget: 0 }, // surface point the crust view is centred on
            cutLon: null,           // longitude the cells are currently cut at
            camDist: (CONFIG.planetRadius - coreRadius) * CONFIG.crustZoom, // crust-view zoom
            viewSnapshot: null,     // saved orbit-camera state while in resource mode
        };

        // persistent highlight for the selected surface cell
        const selection = new THREE.Mesh(
            new THREE.BufferGeometry(),
            new THREE.MeshBasicMaterial({
                color: 0x6fb0ff, transparent: true, opacity: 0.42, side: THREE.DoubleSide,
                depthWrite: false, polygonOffset: true, polygonOffsetFactor: -2, polygonOffsetUnits: -2,
            }),
        );
        selection.visible = false;
        scene.add(selection);
        const selectionEdges = new THREE.LineSegments(
            new THREE.BufferGeometry(),
            new THREE.LineBasicMaterial({ color: 0x9fd0ff }),
        );
        selectionEdges.visible = false;
        scene.add(selectionEdges);

        // ----------------------------------------------------------------------
        // Resource-mode slicing
        //
        // The cells (and core) are cut by a real plane, so the exposed face is
        // always FLAT and stays level with the slice plane — in latitude mode too,
        // where the conical lines of constant latitude make cell-aligned reveals
        // look folded. Plane-clipping alone would let you see into the hollow
        // cells, so each cut cell is closed with a flat cap polygon at the plane.
        // ----------------------------------------------------------------------
        function applyClipping(enabled) {
            const planes = enabled ? [clipPlane] : [];
            for (const m of depthMaterials) { m.clippingPlanes = planes; m.needsUpdate = true; }
            core.material.clippingPlanes = planes; core.material.needsUpdate = true;

            // Sub-surface depth layers stay HIDDEN in both modes:
            //
            //   - view mode: occluded by the surface layer, as always.
            //   - resource mode: the cap-mesh cross-section at the clip plane
            //     plus the surface (depth 0) layer together cover every
            //     fragment a player can actually see, so the deeper shells
            //     are never visible. If we left them enabled, Three.js's
            //     shader-side clipping (`discard` in the fragment shader)
            //     disables early-Z on every clipped material, forcing
            //     ~1.3M sub-surface triangles to run their full Lambert
            //     fragment shader before the depth test rejects them. That
            //     hidden overdraw was the source of the latitude-dependent
            //     frame-rate gradient (cell side-wall normals dot with the
            //     world Y axis asymmetrically against the camera Y position,
            //     so different numbers of back-faces survive culling and
            //     reach the fragment + depth test pipeline at each pole).
            for (let d = 1; d < depthMeshes.length; d++) {
                depthMeshes[d].visible = false;
            }
        }

        // Intersect a quad cell hexahedron with the clip plane -> ordered polygon points.
        function quadCellCrossSection(corners) {
            const n = clipPlane.normal, k = clipPlane.constant;
            const dist = corners.map((v) => n.dot(v) + k);
            const pts = [];

            for (const [a, b] of CELL_EDGES) {
                const da = dist[a], db = dist[b];

                if ((da < 0) !== (db < 0)) {
                    const t = da / (da - db);
                    pts.push(corners[a].clone().lerp(corners[b], t));
                }
            }

            if (pts.length < 3) {
                return null;
            }

            // order the points around their centroid in the plane.
            const c = new THREE.Vector3();
            for (const p of pts) c.add(p);
            c.multiplyScalar(1 / pts.length);

            const u = new THREE.Vector3(1, 0, 0).cross(n);

            if (u.lengthSq() < 1e-6) {
                u.set(0, 0, 1).cross(n);
            }

            u.normalize();
            const v = n.clone().cross(u).normalize();
            pts.sort((p, q) => {
                const pa = Math.atan2(v.dot(p.clone().sub(c)), u.dot(p.clone().sub(c)));
                const qa = Math.atan2(v.dot(q.clone().sub(c)), u.dot(q.clone().sub(c)));

                return pa - qa;
            });

            return pts;
        }

        // Cross-section of a polar cap cell with the meridian clip plane.
        //
        // The cap is rendered with `polarCapRings` concentric subdivisions
        // between the pole and the boundary, so its outer/inner skin is a
        // smooth dome. The meridian clip plane intersects that dome along a
        // CURVED arc — sampling that arc here makes the cap cross-section
        // match the rendered geometry. (The previous 6-point hex made
        // deeper layers look polygonal compared to the dome of the surface
        // layer; with this all depths share the same roundness.)
        //
        // Result is a triangulated quad strip between the outer and inner
        // arcs, returned as {positions, indices} so the caller can emit it
        // verbatim instead of fan-triangulating a non-convex polygon.
        function capCellCrossSection(cell) {
            const { sign, boundaryLat, rOuter, rInner } = cell;
            const lonA = state.focus.lon;
            const lonB = state.focus.lon + 180;
            const poleLat = sign * 90;
            const rings = Math.max(2, CONFIG.polarCapRings ?? 4);

            const outerArc = [];
            const innerArc = [];

            // lonA side: boundary lat → pole (rings + 1 samples).
            for (let i = 0; i <= rings; i++)
            {
                const t = i / rings;
                const lat = boundaryLat + (poleLat - boundaryLat) * t;

                if (i === rings)
                {
                    // Exact pole point (avoids cos(±90) jitter).
                    outerArc.push(new THREE.Vector3(0, sign * rOuter, 0));
                    innerArc.push(new THREE.Vector3(0, sign * rInner, 0));
                }
                else
                {
                    outerArc.push(sphere(lonA, lat, rOuter));
                    innerArc.push(sphere(lonA, lat, rInner));
                }
            }

            // lonB side: pole → boundary lat (skip i=0 — the pole was
            // already pushed above as the apex of the arc).
            for (let i = 1; i <= rings; i++)
            {
                const t = i / rings;
                const lat = poleLat + (boundaryLat - poleLat) * t;
                outerArc.push(sphere(lonB, lat, rOuter));
                innerArc.push(sphere(lonB, lat, rInner));
            }

            const N = outerArc.length;
            const positions = outerArc.concat(innerArc);
            const indices = [];

            // Quad strip between outer arc (0..N-1) and inner arc (N..2N-1).
            for (let i = 0; i < N - 1; i++)
            {
                const o0 = i;
                const o1 = i + 1;
                const i0 = N + i;
                const i1 = N + i + 1;
                indices.push(o0, o1, i1);
                indices.push(o0, i1, i0);
            }

            return { positions, indices };
        }

        // Quad cross-section wrapped in the same {positions, indices} shape
        // so every caller can treat both cell kinds uniformly.
        function cellCrossSection(cell) {
            if (cell.kind === 'cap')
            {
                return capCellCrossSection(cell);
            }

            const pts = quadCellCrossSection(cell.corners);

            if (pts === null) return null;

            const indices = [];
            // Convex polygon — fan-triangulate from pts[0].
            for (let t = 1; t < pts.length - 1; t++)
            {
                indices.push(0, t, t + 1);
            }

            return { positions: pts, indices };
        }

        function clearCaps() {
            while (capsGroup.children.length > 0) {
                const cap = capsGroup.children[capsGroup.children.length - 1];
                capsGroup.remove(cap);
                cap.geometry.dispose();
            }

            capMeshes.length = 0;
        }

        // Which longitude columns can the meridian plane possibly cut?
        // A meridian plane through `focus.lon` intersects the body along that
        // longitude AND its antipode (focus.lon + 180). Any cell whose [lon0,
        // lon1] range contains either of those is a candidate; everything else
        // has an empty cross-section. So instead of testing every cell, we
        // only touch ~2 columns per drag tick.
        function cutColumns(focusLon) {
            const w = 360 / CONFIG.lonCells;
            const cols = new Set();
            const eps = 1e-6;

            for (const base of [focusLon, focusLon + 180]) {
                const norm = ((base % 360) + 360) % 360;
                // Include both sides of an exact boundary, just in case.
                cols.add(Math.floor((norm - eps + 360) % 360 / w));
                cols.add(Math.floor((norm + eps) % 360 / w));
            }

            return cols;
        }

        function buildCaps() {
            clearCaps();

            const n = clipPlane.normal;
            const lift = CONFIG.planetRadius * 0.0015; // nudge caps just off the cut, toward the camera

            // Merged cap buffers, one per depth.
            const buffers = depthColors.map(() => ({
                positions: [],
                normals: [],
                faceToCell: [], // triangle index → cell record (for raycast picking)
            }));

            const cols = cutColumns(state.focus.lon);

            for (let d = 0; d < maxDepth; d++) {
                for (const cell of cellsByDepth[d]) {
                    // Quad cells only need testing if they're in a column the
                    // cut could possibly cross. Cap cells are always cut by a
                    // meridian plane, so they fall through.
                    if (cell.kind === 'quad' && !cols.has(cell.lonIdx)) {
                        continue;
                    }

                    const cross = cellCrossSection(cell);

                    if (cross === null) {
                        continue;
                    }

                    const buf = buffers[d];
                    const pts = cross.positions;
                    const idx = cross.indices;

                    // Each triangle in the cross-section becomes 3 flat-shaded
                    // vertices in the merged buffer, with the per-tri index
                    // recorded against the cell so raycast picking still
                    // resolves to it.
                    for (let t = 0; t < idx.length; t += 3) {
                        const a = pts[idx[t]];
                        const b = pts[idx[t + 1]];
                        const c = pts[idx[t + 2]];

                        for (const p of [a, b, c]) {
                            buf.positions.push(p.x - n.x * lift, p.y - n.y * lift, p.z - n.z * lift);
                            // Flat cap normals all point along -n (toward camera side).
                            buf.normals.push(-n.x, -n.y, -n.z);
                        }

                        buf.faceToCell.push(cell);
                    }
                }
            }

            // Emit one merged cap mesh per depth (≤ maxDepth draw calls instead
            // of one per sliced cell). Each carries a faceIndex → cell map so
            // raycasting still resolves to the right cell.
            for (let d = 0; d < maxDepth; d++) {
                const buf = buffers[d];

                if (buf.positions.length === 0) {
                    continue;
                }

                const geo = new THREE.BufferGeometry();
                geo.setAttribute('position', new THREE.Float32BufferAttribute(buf.positions, 3));
                geo.setAttribute('normal', new THREE.Float32BufferAttribute(buf.normals, 3));
                geo.computeBoundingSphere();

                const cap = new THREE.Mesh(geo, capMaterials[d]);
                cap.userData.faceToCell = buf.faceToCell;
                capsGroup.add(cap);
                capMeshes.push(cap);
            }

            // flat cap for the smooth core so it stays level with the slice too.
            // Use the exact `coreRadius` (matching the sphere geometry and the
            // deepest layer's inner radius) so the cross-section is continuous
            // from crust → core with no gap.
            const coreR = coreRadius;
            const k = clipPlane.constant;

            if (coreR * coreR > k * k) {
                const discR = Math.sqrt(coreR * coreR - k * k);
                const disc = new THREE.Mesh(
                    new THREE.CircleGeometry(discR, 48),
                    coreCapMaterial,
                );
                // orient the disc to the plane and place it at the plane.
                disc.quaternion.setFromUnitVectors(new THREE.Vector3(0, 0, 1), n);
                disc.position.copy(n).multiplyScalar(-k - lift);
                capsGroup.add(disc);
                // Note: not added to capMeshes — the core isn't a clickable cell.
            }
        }

        function updateCut() {
            // meridian (constant-longitude) plane through the poles at the focus
            // longitude — exposes a vertical crust cliff (surface→depth). Rebuilt
            // only when the longitude changes.
            const lonR = deg2rad(state.focus.lon);
            clipPlane.normal.set(Math.sin(lonR), 0, -Math.cos(lonR));
            clipPlane.constant = 0;
            buildCaps();
            state.cutLon = state.focus.lon;
            // The hover highlight in resource mode is a cross-section on the
            // clip plane — invalidate the hover cache so the next frame
            // rebuilds the geometry against the new plane.
            hoverCache.pointerX = NaN;
        }

        // Position the camera to look at the crust cliff edge-on at the focus point,
        // so the surface-to-max-depth layers run top→bottom. Derived from the focus
        // point on the sphere, so it follows the body's curvature.
        function positionCrustCamera() {
            const lonR = deg2rad(state.focus.lon);
            const latR = deg2rad(state.focus.lat);
            const midR = (CONFIG.planetRadius + coreRadius) / 2;

            // local radial (surface "up") and the meridian-plane normal (east-west).
            const radialUp = new THREE.Vector3(
                Math.cos(latR) * Math.cos(lonR),
                Math.sin(latR),
                Math.cos(latR) * Math.sin(lonR),
            );
            const m = new THREE.Vector3(-Math.sin(lonR), 0, Math.cos(lonR));

            const crustThickness = CONFIG.planetRadius - coreRadius;
            const target = radialUp.clone().multiplyScalar(midR + crustThickness * CONFIG.crustHeightBias);

            const tilt = CONFIG.crustTilt; // tilt above the meridian plane (look down at surface)
            const camPos = target.clone()
                .add(m.clone().multiplyScalar(state.camDist * Math.cos(tilt)))
                .add(radialUp.clone().multiplyScalar(state.camDist * Math.sin(tilt)));

            camera.position.copy(camPos);
            camera.up.copy(radialUp); // keep depth pointing down on screen
            camera.lookAt(target);
        }

        function updateFocusReadout() {
            document.getElementById('rSlice').textContent =
                `lon ${state.focus.lon.toFixed(0)}° · lat ${state.focus.lat.toFixed(0)}°`;
        }

        // Called while strolling. Only rebuilds the (expensive) caps when the cut
        // longitude actually changes; latitude changes just move the camera.
        function updateResource(lonChanged) {
            if (lonChanged || state.cutLon === null) {
                updateCut();
            }

            positionCrustCamera();
            updateFocusReadout();
        }

        // ----------------------------------------------------------------------
        // Mode switching
        // ----------------------------------------------------------------------
        const modeBtn = document.getElementById('modeBtn');
        const resourceControls = document.getElementById('resourceControls');

        function setMode(mode) {
            // resource mode requires a selected surface cell to anchor the view.
            if (mode === 'resource' && state.selected === null) {
                return;
            }

            const wasResource = state.mode === 'resource';
            state.mode = mode;
            const resource = mode === 'resource';

            applyClipping(resource);
            sliceVisual.visible = false;
            // grid stays hidden in both modes — see the buildGrid() call above.
            controls.enabled = !resource; // custom drag drives the crust view
            selection.visible = selectionEdges.visible = !resource && state.selected !== null;

            resourceControls.hidden = !resource;
            modeBtn.textContent = resource ? 'Exit resource mode' : 'Enter resource mode';
            document.getElementById('rMode').textContent = mode;

            if (resource) {
                // Snapshot the orbit-camera state so we can return to it on exit.
                if (!wasResource) {
                    state.viewSnapshot = {
                        position: camera.position.clone(),
                        up:       camera.up.clone(),
                        target:   controls.target.clone(),
                    };
                }

                state.focus.lon = state.selected.lon;
                state.focus.lat = state.selected.lat;
                state.focus.lonTarget = snapLonToCol(state.selected.lon);
                state.focus.latTarget = snapLatToRow(state.selected.lat);
                state.focus.lon = state.focus.lonTarget;
                state.focus.lat = state.focus.latTarget;
                state.cutLon = null;
                updateResource(true);
            } else {
                clearCaps();

                // Restore the pre-resource view so we don't snap to a default.
                if (state.viewSnapshot) {
                    camera.position.copy(state.viewSnapshot.position);
                    camera.up.copy(state.viewSnapshot.up);
                    controls.target.copy(state.viewSnapshot.target);
                } else {
                    controls.target.set(0, 0, 0);
                }

                controls.update();
            }
        }

        modeBtn.addEventListener('click', () => setMode(state.mode === 'view' ? 'resource' : 'view'));

        function refreshModeButton() {
            modeBtn.disabled = state.selected === null;
        }

        // ----------------------------------------------------------------------
        // Input — drag strolls the crust in resource mode, wheel zooms
        // ----------------------------------------------------------------------
        const drag = { active: false, x: 0, y: 0 };

        // Snap a latitude to the centre of the nearest quad-cell row, clamped
        // to the non-cap band (polar caps aren't part of the snap grid — the
        // crust view is anchored on quad cells). Used to settle the
        // horizontal scroll on a cell after the user releases the mouse.
        function snapLatToRow(lat) {
            const minLat = -90 + capRows * rowDegLat + rowDegLat / 2;
            const maxLat =  90 - capRows * rowDegLat - rowDegLat / 2;
            const clamped = Math.max(minLat, Math.min(maxLat, lat));
            const idx = Math.round((clamped - minLat) / rowDegLat);

            return minLat + idx * rowDegLat;
        }

        // Snap a longitude to the centre of the nearest quad-cell column. The
        // longitude axis wraps, so we work modulo 360 and let the easing
        // resolve direction via shortest-path.
        function snapLonToCol(lon) {
            const colDeg = 360 / CONFIG.lonCells;
            const norm = ((lon % 360) + 360) % 360;
            const idx = Math.round((norm - colDeg / 2) / colDeg);

            return ((idx * colDeg + colDeg / 2) % 360 + 360) % 360;
        }

        // How many degrees of lat/lon does ONE screen pixel of drag correspond
        // to right now? Derived from the perspective camera's FOV and the
        // current crust-view distance, so the cursor stays glued to the
        // surface regardless of zoom. `CONFIG.dragSensitivity` scales this
        // (1 = 1:1 with the cursor).
        function dragDegPerPixel() {
            const h = renderer.domElement.clientHeight || 1;
            const midR = (CONFIG.planetRadius + coreRadius) / 2;
            // World units per screen pixel at the focus distance.
            const worldPerPx = (2 * state.camDist * Math.tan(deg2rad(camera.fov) / 2)) / h;
            // 1° of latitude is `midR * π/180` world units along the meridian.
            const degLatPerPx = worldPerPx * 180 / Math.PI / midR;
            // 1° of longitude shrinks with cos(lat); clamp near the poles so
            // the response doesn't blow up.
            const cosLat = Math.max(Math.cos(deg2rad(state.focus.lat)), 0.05);
            const degLonPerPx = degLatPerPx / cosLat;

            return {
                lat: degLatPerPx * CONFIG.dragSensitivity,
                lon: degLonPerPx * CONFIG.dragSensitivity,
            };
        }

        renderer.domElement.addEventListener('pointerdown', (e) => {
            if (state.mode !== 'resource') return;
            drag.active = true;
            drag.x = e.clientX;
            drag.y = e.clientY;
        });

        window.addEventListener('pointerup', () => {
            if (!drag.active) return;
            drag.active = false;
            // Settle on a cell: snap the targets to the nearest column/row
            // and let `easeFocusToTarget()` glide the remaining distance —
            // same feel as OrbitControls' damped stop in view mode.
            if (state.mode === 'resource')
            {
                state.focus.lonTarget = snapLonToCol(state.focus.lonTarget);
                state.focus.latTarget = snapLatToRow(state.focus.latTarget);
            }
        });

        window.addEventListener('pointermove', (e) => {
            if (!drag.active || state.mode !== 'resource') return;

            const dx = e.clientX - drag.x;
            const dy = e.clientY - drag.y;
            drag.x = e.clientX;
            drag.y = e.clientY;

            const dpp = dragDegPerPixel();
            // Move TARGETS continuously — the animation loop is what advances
            // the actual focus toward them. Snapping happens on pointerup so
            // the user gets smooth, analog-feeling tracking during the drag
            // and a clean cell-aligned settle when they let go.
            const minLat = -90 + capRows * rowDegLat + rowDegLat / 2;
            const maxLat =  90 - capRows * rowDegLat - rowDegLat / 2;
            state.focus.lonTarget = (state.focus.lonTarget + dy * dpp.lon + 360) % 360;
            state.focus.latTarget = Math.max(minLat, Math.min(maxLat,
                state.focus.latTarget + dx * dpp.lat));
        });

        renderer.domElement.addEventListener('wheel', (e) => {
            if (state.mode !== 'resource') return; // OrbitControls zooms in view mode
            e.preventDefault();

            const min = (CONFIG.planetRadius - coreRadius) * CONFIG.crustZoomMin;
            const max = (CONFIG.planetRadius - coreRadius) * CONFIG.crustZoomMax;
            state.camDist = Math.max(min, Math.min(max, state.camDist * (e.deltaY > 0 ? 1.1 : 0.9)));
            positionCrustCamera();
        }, { passive: false });

        window.addEventListener('keydown', (e) => {
            const k = e.key.toLowerCase();

            if (k === 'r') {
                setMode(state.mode === 'view' ? 'resource' : 'view');
                return;
            }

            if (state.mode !== 'resource') return;

            const colDeg = 360 / CONFIG.lonCells;

            // Arrow keys step targets one full cell; easing carries the
            // visible focus in smoothly.
            if (e.key === 'ArrowUp')    state.focus.lonTarget = snapLonToCol(state.focus.lonTarget + colDeg);
            if (e.key === 'ArrowDown')  state.focus.lonTarget = snapLonToCol(state.focus.lonTarget - colDeg);
            if (e.key === 'ArrowLeft')  state.focus.latTarget = snapLatToRow(state.focus.latTarget + rowDegLat);
            if (e.key === 'ArrowRight') state.focus.latTarget = snapLatToRow(state.focus.latTarget - rowDegLat);
        });

        // ----------------------------------------------------------------------
        // Raycasting — hover highlight + coordinate readout
        // ----------------------------------------------------------------------
        const raycaster = new THREE.Raycaster();
        const pointer = new THREE.Vector2();
        let pointerInside = false;
        // Cache so updateHover() can skip its work entirely on frames where
        // neither the cursor nor the camera moved (very common: animate()
        // runs every frame, but mouse + camera are static most of the time).
        const hoverCache = {
            pointerX: NaN,
            pointerY: NaN,
            camX: NaN, camY: NaN, camZ: NaN,
            camQx: NaN, camQy: NaN, camQz: NaN, camQw: NaN,
            inside: false,
            mode: null,
        };

        renderer.domElement.addEventListener('pointermove', (e) => {
            const rect = renderer.domElement.getBoundingClientRect();
            pointer.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
            pointer.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
            pointerInside = true;
        });
        renderer.domElement.addEventListener('pointerleave', () => { pointerInside = false; });

        // Distinguish a real click from the end of an orbit-drag in view mode.
        // OrbitControls consumes the drag, but the browser still fires `click`
        // on pointerup if the press and release were on the same element —
        // which would select a different cell whenever the user finished
        // panning over the planet. Track the press position and treat any
        // release that moved more than `CLICK_SLOP_PX` as a drag, not a click.
        const CLICK_SLOP_PX = 4;
        const pressOrigin = { x: 0, y: 0, valid: false };
        renderer.domElement.addEventListener('pointerdown', (e) => {
            pressOrigin.x = e.clientX;
            pressOrigin.y = e.clientY;
            pressOrigin.valid = true;
        });

        renderer.domElement.addEventListener('click', (e) => {
            if (!highlight.visible) return;

            // Reject the synthetic `click` that fires at the end of a drag
            // (orbit in view mode, stroll in resource mode). Movement past
            // CLICK_SLOP_PX means the user was dragging, not clicking.
            if (pressOrigin.valid)
            {
                const moved = Math.hypot(e.clientX - pressOrigin.x, e.clientY - pressOrigin.y);
                pressOrigin.valid = false;

                if (moved > CLICK_SLOP_PX) return;
            }

            const cell = highlight.userData.cell;

            if (!cell) return;

            if (state.mode === 'view')
            {
                // Only surface cells (depth 0) can be picked as the anchor
                // that unlocks resource mode.
                if (cell.depth !== 0) return;

                selectSurfaceCell(cell);
                return;
            }

            // Resource mode: clicking a cell on the cliff snaps the camera
            // focus to that cell. Same easing as the arrow-key step, so the
            // transition feels identical to keyboard navigation.
            //
            // Clicking on the antipodal half of the cliff (lon = focus.lon
            // + 180) would normally rebuild the cut at a new meridian — but
            // that meridian IS the same great circle, just inverted, which
            // is visually disorienting. So we only adopt the cell's latitude
            // (and depth readout); the meridian stays put.
            state.focus.latTarget = snapLatToRow(cell.lat);
            // Don't touch lonTarget — the cut is already at the right
            // meridian. The easing in easeFocusToTarget() will glide the
            // visible focus over to the new latitude.
        });

        function selectSurfaceCell(cell) {
            state.selected = cell;
            selection.geometry = getCellGeom(cell);
            selectionEdges.geometry = getCellEdges(cell);
            selection.visible = selectionEdges.visible = true;

            state.focus.lon = cell.lon;
            state.focus.lat = cell.lat;

            document.getElementById('rSelected').textContent =
                `lon ${cell.lon.toFixed(0)}° · lat ${cell.lat.toFixed(0)}°`;

            refreshModeButton();
        }

        function updateHover() {
            // Cheap short-circuit: if nothing that could affect the pick has
            // changed since the last frame, the previous result is still
            // valid and we can skip both the raycast and the DOM writes.
            const camPos = camera.position;
            const camQ = camera.quaternion;

            if (
                hoverCache.inside === pointerInside &&
                hoverCache.mode === state.mode &&
                hoverCache.pointerX === pointer.x &&
                hoverCache.pointerY === pointer.y &&
                hoverCache.camX === camPos.x && hoverCache.camY === camPos.y && hoverCache.camZ === camPos.z &&
                hoverCache.camQx === camQ.x && hoverCache.camQy === camQ.y &&
                hoverCache.camQz === camQ.z && hoverCache.camQw === camQ.w
            )
            {
                return;
            }

            hoverCache.inside = pointerInside;
            hoverCache.mode = state.mode;
            hoverCache.pointerX = pointer.x;
            hoverCache.pointerY = pointer.y;
            hoverCache.camX = camPos.x; hoverCache.camY = camPos.y; hoverCache.camZ = camPos.z;
            hoverCache.camQx = camQ.x; hoverCache.camQy = camQ.y;
            hoverCache.camQz = camQ.z; hoverCache.camQw = camQ.w;

            const elLon = document.getElementById('rLon');
            const elLat = document.getElementById('rLat');
            const elDepth = document.getElementById('rDepth');

            if (!pointerInside) {
                highlight.visible = highlightEdges.visible = false;
                elLon.textContent = elLat.textContent = elDepth.textContent = '—';
                return;
            }

            raycaster.setFromCamera(pointer, camera);

            let cell = null;

            if (state.mode === 'resource')
            {
                // Cap caps carry arbitrary cut geometry, so keep the
                // raycaster here — there's no closed-form shortcut.
                const hit = raycaster.intersectObjects(capMeshes, false)[0];
                if (hit) cell = hit.object.userData.faceToCell[hit.faceIndex];
            }
            else
            {
                // View mode: depth-0 mesh is a sphere of `planetRadius`,
                // pick analytically instead of brute-forcing 125k tris.
                cell = pickSurfaceCellAnalytical();
            }

            if (!cell) {
                highlight.visible = highlightEdges.visible = false;
                elLon.textContent = elLat.textContent = elDepth.textContent = '—';
                return;
            }

            // Swap in the right geometry for the mode:
            //   - view mode: full cached hex (only the outer face is visible).
            //   - resource mode: a slim mesh of just the visible faces, rebuilt
            //     each hover because it depends on the current clip plane.
            // Dispose any previously-owned geometry on the highlight meshes
            // before reassigning so we don't leak GPU buffers.
            if (highlight.userData.ownsGeom)
            {
                highlight.geometry.dispose();
                highlightEdges.geometry.dispose();
                highlight.userData.ownsGeom = false;
            }

            if (state.mode === 'resource')
            {
                const geom = buildResourceHighlightGeometry(cell);
                highlight.geometry = geom;
                // Cap cells include a faceted dome — use a wider angle
                // so EdgesGeometry only traces the outline, not every
                // ring crease (same trick `getCellEdges` uses).
                const thresh = cell.kind === 'cap' ? 30 : 1;
                highlightEdges.geometry = new THREE.EdgesGeometry(geom, thresh);
                highlight.userData.ownsGeom = true;
            }
            else
            {
                highlight.geometry = getCellGeom(cell);
                highlightEdges.geometry = getCellEdges(cell);
            }

            highlight.visible = highlightEdges.visible = true;
            highlight.userData.cell = cell;

            elLon.textContent = `${cell.lon.toFixed(1)}°`;
            elLat.textContent = `${cell.lat.toFixed(1)}°`;
            elDepth.textContent = `${cell.depth + 1} / ${maxDepth}`;
        }

        // ----------------------------------------------------------------------
        // Resize + render loop
        // ----------------------------------------------------------------------
        function resize() {
            const w = root.clientWidth, h = root.clientHeight;
            renderer.setSize(w, h); // updates both drawing buffer and CSS size
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
        }
        window.addEventListener('resize', resize);
        resize();

        // ----------------------------------------------------------------------
        // Sun-position sliders
        // ----------------------------------------------------------------------
        const sunAzInput   = document.getElementById('sunAz');
        const sunElInput   = document.getElementById('sunEl');
        const sunIntInput  = document.getElementById('sunInt');
        const sunAzReadout = document.getElementById('rSunAz');
        const sunElReadout = document.getElementById('rSunEl');
        const sunIntReadout = document.getElementById('rSunInt');

        function syncSunReadouts() {
            sunAzReadout.textContent  = `${Math.round(CONFIG.sunAzimuth)}°`;
            sunElReadout.textContent  = `${Math.round(CONFIG.sunElevation)}°`;
            sunIntReadout.textContent = CONFIG.sunIntensity.toFixed(2);
        }

        sunAzInput.value  = CONFIG.sunAzimuth;
        sunElInput.value  = CONFIG.sunElevation;
        sunIntInput.value = CONFIG.sunIntensity;
        syncSunReadouts();

        sunAzInput.addEventListener('input', () => {
            CONFIG.sunAzimuth = parseFloat(sunAzInput.value);
            updateSun(); syncSunReadouts();
        });
        sunElInput.addEventListener('input', () => {
            CONFIG.sunElevation = parseFloat(sunElInput.value);
            updateSun(); syncSunReadouts();
        });
        sunIntInput.addEventListener('input', () => {
            CONFIG.sunIntensity = parseFloat(sunIntInput.value);
            updateSun(); syncSunReadouts();
        });

        // ----------------------------------------------------------------------
        // Compass — the HUD widget points to true north as projected on screen.
        //
        // The planet's spin axis is +Y in world space, so the "north pole
        // direction" is just (0, 1, 0). Project that into the camera's screen
        // basis (its right and up columns) to get the on-screen 2D heading of
        // north, and rotate the compass rose to match. The compass therefore
        // reads correctly in BOTH view mode (orbit camera, any orientation)
        // and resource mode — where horizontal screen drags map to north/
        // south along the cliff, the compass makes that mapping obvious.
        // ----------------------------------------------------------------------
        const compassRose = document.getElementById('compassRose');
        const _camRight = new THREE.Vector3();
        const _camUp = new THREE.Vector3();

        function updateCompass() {
            if (!compassRose) return;

            _camRight.setFromMatrixColumn(camera.matrixWorld, 0);
            _camUp.setFromMatrixColumn(camera.matrixWorld, 1);

            // World-space north pole direction projected onto the camera's
            // screen basis:
            //   x = north-pole's projection along screen-right
            //   y = north-pole's projection along screen-up
            const x = _camRight.y;
            const y = _camUp.y;

            // CSS rotates clockwise; atan2(x, y) measures clockwise from the
            // +y (screen-up) axis, which is exactly the rose's "N at the top"
            // convention.
            const deg = Math.atan2(x, y) * 180 / Math.PI;
            compassRose.setAttribute('transform', `rotate(${deg.toFixed(2)})`);
        }

        // ----------------------------------------------------------------------
        // FPS / frame-time counter (EMA-smoothed; updated to the HUD ~4×/sec
        // so the numbers stay readable).
        // ----------------------------------------------------------------------
        const fpsEl = document.getElementById('rFps');
        const frameMsEl = document.getElementById('rFrameMs');
        const perf = { last: performance.now(), ema: 0, lastHud: 0 };

        function updateFps(now) {
            const dt = now - perf.last;
            perf.last = now;
            // 0.1 = ~10-frame time-constant; resistant to single-frame spikes.
            perf.ema = perf.ema === 0 ? dt : perf.ema + (dt - perf.ema) * 0.1;

            if (now - perf.lastHud > 250) {
                fpsEl.textContent = (1000 / perf.ema).toFixed(0);
                frameMsEl.textContent = `${perf.ema.toFixed(1)} ms`;
                perf.lastHud = now;
            }
        }

        function animate() {
            requestAnimationFrame(animate);
            const now = performance.now();
            updateFps(now);
            if (state.mode === 'view') controls.update(); // crust view is driven manually
            else easeFocusToTarget();                     // smooth snap in resource mode
            // Track the camera so the sky group (sun, halo, chroma ring, stars)
            // appears fixed at infinity — no parallax.
            skyAnchor.position.copy(camera.position);
            updateHover();
            updateCompass();
            updateLensFlare(now);
            // Atmosphere shader: sun direction is the only per-frame uniform
            // (camera position is already a built-in). Cheap to copy each
            // frame and keeps the rim glow in lock-step with the sliders.
            atmosphereUniforms.uSunDir.value.copy(sunDir);
            renderer.render(scene, camera);
        }

        // Glide state.focus.{lon,lat} toward their targets every frame. Both
        // axes use the same exponential ease so a drag-and-release in resource
        // mode feels just like releasing an OrbitControls orbit in view mode:
        // analog while you drag, then a short damped settle onto the cell.
        // Longitude eases along the shortest arc across the 0/360 wrap.
        function easeFocusToTarget() {
            const EPS = 1e-3;
            const ease = CONFIG.focusSnapEase;
            let lonChanged = false;
            let moved = false;

            let dLon = state.focus.lonTarget - state.focus.lon;
            if (dLon > 180)  dLon -= 360;
            if (dLon < -180) dLon += 360;

            if (Math.abs(dLon) > EPS)
            {
                state.focus.lon = (state.focus.lon + dLon * ease + 360) % 360;
                lonChanged = true;
                moved = true;
            }
            else if (state.focus.lon !== state.focus.lonTarget)
            {
                state.focus.lon = state.focus.lonTarget;
                lonChanged = true;
                moved = true;
            }

            const dLat = state.focus.latTarget - state.focus.lat;

            if (Math.abs(dLat) > EPS)
            {
                state.focus.lat += dLat * ease;
                moved = true;
            }
            else if (state.focus.lat !== state.focus.latTarget)
            {
                state.focus.lat = state.focus.latTarget;
                moved = true;
            }

            if (moved) updateResource(lonChanged);
        }
        animate();
    </script>
{% endblock %}

